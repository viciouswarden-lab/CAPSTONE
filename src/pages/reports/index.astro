---
/**
 * Reports and Analytics Page - Client-Side Rendering
 * 
 * Generates sales, inventory, and supplier performance reports.
 * All data loaded client-side from Firestore.
 */

import ModernLayout from '../../layouts/ModernLayout.astro';

// Disable caching
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');

const pageTitle = 'Reports & Analytics';
---

<ModernLayout title={pageTitle}>
  <!-- Loading State -->
  <div id="loading-state" class="loading-container">
    <div class="spinner"></div>
    <p style="margin-top: 1rem; color: var(--text-secondary);">Loading reports...</p>
  </div>

  <!-- Content (hidden until loaded) -->
  <div id="reports-content" class="hidden">
    <!-- Page Header -->
    <div class="page-header">
      <div class="page-header-content">
        <h1>Reports & Analytics</h1>
        <p>Generate customizable reports for sales, inventory, and suppliers</p>
      </div>
      <div class="page-header-actions">
        <button class="btn btn-secondary" id="scheduled-reports-btn">
          <span class="material-symbols-outlined">schedule</span>
          Scheduled Reports
        </button>
      </div>
    </div>

    <!-- Report View Modal -->
    <div id="report-modal" class="modal-overlay hidden">
      <div class="modal-container" style="max-width: 900px;">
        <div class="modal-header">
          <h2 id="modal-title">Report Details</h2>
          <button class="btn-ghost" id="close-modal" style="padding: 0.5rem;">
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>
        <div class="modal-body" style="max-height: 70vh; overflow-y: auto;">
          <div id="report-content">
            <!-- Report content will be loaded here -->
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" id="modal-download-pdf">
            <span class="material-symbols-outlined">download</span>
            Download PDF
          </button>
          <button class="btn btn-secondary" id="modal-export-excel">
            <span class="material-symbols-outlined">table_chart</span>
            Export Excel
          </button>
          <button class="btn btn-primary" id="modal-close-btn">Close</button>
        </div>
      </div>
    </div>

    <!-- Report Templates -->
    <div style="margin-bottom: 2rem;">
      <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem;">Report Templates</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;" id="templates-container">
        <!-- Templates will be loaded here -->
      </div>
    </div>

    <!-- Recent Reports -->
    <div class="card">
      <div class="card-header">
        <h2>Recent Reports</h2>
        <span class="badge badge-info" id="reports-count">0 reports</span>
      </div>
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Report</th>
              <th>Type</th>
              <th>Generated</th>
              <th>Generated By</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="reports-tbody">
            <!-- Reports will be loaded here -->
          </tbody>
        </table>
      </div>
      <div id="no-reports" class="hidden" style="padding: 2rem; text-align: center; color: var(--text-secondary);">
        <span class="material-symbols-outlined" style="font-size: 48px; opacity: 0.5;">description</span>
        <p style="margin-top: 1rem;">No reports generated yet</p>
        <p style="font-size: 0.875rem;">Generate your first report using a template above</p>
      </div>
    </div>
  </div>

  <script>
    import { initializeApp } from 'firebase/app';
    import { getFirestore, collection, query, where, getDocs, getDoc, doc, addDoc, Timestamp, orderBy, limit } from 'firebase/firestore';
    import { getAuth } from 'firebase/auth';

    const firebaseConfig = {
      apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY,
      authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
      projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
      storageBucket: import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
      messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID,
      appId: import.meta.env.PUBLIC_FIREBASE_APP_ID,
    };

    const app = initializeApp(firebaseConfig);
    const db = getFirestore(app);
    const auth = getAuth(app);

    const loadingState = document.getElementById('loading-state')!;
    const reportsContent = document.getElementById('reports-content')!;

    // Report templates
    const reportTemplates = [
      {
        id: 'sales-summary',
        name: 'Sales Summary',
        description: 'Revenue, units sold, and transaction analysis',
        icon: 'trending_up',
        category: 'Sales',
      },
      {
        id: 'inventory-status',
        name: 'Inventory Status',
        description: 'Stock levels, value, and turnover rates',
        icon: 'warehouse',
        category: 'Inventory',
      },
      {
        id: 'supplier-performance',
        name: 'Supplier Performance',
        description: 'Price stability, delivery reliability, and metrics',
        icon: 'store',
        category: 'Suppliers',
      },
    ];

    const formatDateTime = (date: Date) => {
      return new Intl.DateTimeFormat('en-US', {
        month: 'short',
        day: 'numeric',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit',
      }).format(date);
    };

    const formatCurrency = (value: number) => {
      return new Intl.NumberFormat('en-PH', {
        style: 'currency',
        currency: 'PHP',
      }).format(value);
    };

    // Generate report data based on template type
    const generateReportData = async (templateId: string) => {
      const now = new Date();
      const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);

      try {
        if (templateId === 'sales-summary') {
          // Get sales transactions for the current month
          const transactionsRef = collection(db, 'pos_transactions');
          const monthQuery = query(
            transactionsRef,
            where('timestamp', '>=', Timestamp.fromDate(monthStart))
          );
          const transactionsSnap = await getDocs(monthQuery);

          console.log('Sales transactions found:', transactionsSnap.size);

          let totalRevenue = 0;
          let totalTransactions = 0;
          const dailySales: { [key: string]: number } = {};
          const paymentMethods: { [key: string]: number } = {};
          const productsSold: { [key: string]: { name: string; quantity: number; revenue: number } } = {};

          transactionsSnap.forEach(doc => {
            const data = doc.data();
            // Count all transactions, filter by completed for revenue
            if (data.status === 'completed') {
              totalRevenue += data.total || 0;
              totalTransactions++;

              // Daily sales
              const date = data.timestamp?.toDate().toLocaleDateString('en-US') || 'Unknown';
              dailySales[date] = (dailySales[date] || 0) + (data.total || 0);

              // Payment methods
              const payment = data.paymentMethod || 'Unknown';
              paymentMethods[payment] = (paymentMethods[payment] || 0) + 1;

              // Products sold
              if (data.items && Array.isArray(data.items)) {
                data.items.forEach((item: any) => {
                  const sku = item.sku || 'Unknown';
                  if (!productsSold[sku]) {
                    productsSold[sku] = { name: item.name || 'Unknown Product', quantity: 0, revenue: 0 };
                  }
                  productsSold[sku].quantity += item.quantity || 0;
                  productsSold[sku].revenue += item.total || 0;
                });
              }
            }
          });

          const reportData = {
            summary: {
              totalRevenue,
              totalTransactions,
              averageTransaction: totalTransactions > 0 ? totalRevenue / totalTransactions : 0,
            },
            dailySales,
            paymentMethods,
            topProducts: Object.entries(productsSold)
              .sort((a, b) => b[1].revenue - a[1].revenue)
              .slice(0, 10)
              .map(([sku, prod]) => ({
                sku,
                name: prod.name,
                quantity: prod.quantity,
                revenue: prod.revenue,
              })),
          };

          console.log('Sales report data:', reportData);
          return reportData;

        } else if (templateId === 'inventory-status') {
          // Get inventory data
          const inventoryRef = collection(db, 'inventory');
          const inventorySnap = await getDocs(inventoryRef);
          const productsRef = collection(db, 'products');
          const productsSnap = await getDocs(productsRef);

          console.log('Inventory items found:', inventorySnap.size);
          console.log('Products found:', productsSnap.size);

          let totalValue = 0;
          let totalItems = 0;
          let lowStockItems = 0;
          const inventoryItems: any[] = [];

          inventorySnap.forEach(invDoc => {
            const invData = invDoc.data();
            const sku = invData.sku || invDoc.id.split('_')[0];
            const qty = invData.quantityOnHand || 0;

            // Find matching product
            const productDoc = productsSnap.docs.find(p => p.id === sku || p.data().sku === sku);
            if (productDoc) {
              const productData = productDoc.data();
              const reorderPoint = productData.reorderPoint || 0;
              const cost = productData.cost || 0;
              const value = qty * cost;

              totalValue += value;
              totalItems += qty;
              if (qty <= reorderPoint) lowStockItems++;

              inventoryItems.push({
                sku,
                name: productData.name || 'Unknown',
                quantity: qty,
                reorderPoint,
                cost,
                value,
                status: qty <= reorderPoint ? 'Low Stock' : 'In Stock',
              });
            }
          });

          const reportData = {
            summary: {
              totalValue,
              totalItems,
              lowStockItems,
              uniqueProducts: inventoryItems.length,
            },
            items: inventoryItems.sort((a, b) => b.value - a.value),
          };

          console.log('Inventory report data:', reportData);
          return reportData;

        } else if (templateId === 'supplier-performance') {
          // Get supplier and pricelist data
          const suppliersRef = collection(db, 'suppliers');
          const suppliersSnap = await getDocs(suppliersRef);
          const pricelistsRef = collection(db, 'pricelists');
          const pricelistsSnap = await getDocs(pricelistsRef);

          console.log('Suppliers found:', suppliersSnap.size);
          console.log('Pricelists found:', pricelistsSnap.size);

          const supplierMetrics: any[] = [];

          suppliersSnap.forEach(supplierDoc => {
            const supplierData = supplierDoc.data();
            const supplierId = supplierDoc.id;

            // Count pricelists for this supplier
            const supplierPricelists = pricelistsSnap.docs.filter(
              p => p.data().supplierId === supplierId
            );

            // Get latest update date
            let lastUpdate = 'Never';
            if (supplierPricelists.length > 0) {
              const latestPricelist = supplierPricelists.sort((a, b) => {
                const aDate = a.data().uploadedAt?.toDate() || new Date(0);
                const bDate = b.data().uploadedAt?.toDate() || new Date(0);
                return bDate.getTime() - aDate.getTime();
              })[0];
              lastUpdate = latestPricelist.data().uploadedAt?.toDate().toLocaleDateString('en-US') || 'Never';
            }

            supplierMetrics.push({
              name: supplierData.name || 'Unknown',
              contactPerson: supplierData.contactPerson || 'N/A',
              email: supplierData.email || 'N/A',
              phone: supplierData.phone || 'N/A',
              pricelistCount: supplierPricelists.length,
              lastUpdate,
              status: supplierData.isActive ? 'Active' : 'Inactive',
            });
          });

          const reportData = {
            summary: {
              totalSuppliers: supplierMetrics.length,
              activeSuppliers: supplierMetrics.filter(s => s.status === 'Active').length,
              totalPricelists: pricelistsSnap.size,
            },
            suppliers: supplierMetrics.sort((a, b) => b.pricelistCount - a.pricelistCount),
          };

          console.log('Supplier report data:', reportData);
          return reportData;
        }

      } catch (error) {
        console.error('Error generating report data:', error);
        throw error;
      }

      return null;
    };

    const generateReport = async (templateId: string, templateName: string, category: string) => {
      try {
        const user = auth.currentUser;
        if (!user) {
          alert('Please sign in to generate reports');
          return;
        }

        // Show generating message
        const btn = (window.event?.target as HTMLElement)?.closest('button') as HTMLButtonElement;
        const originalText = btn?.innerHTML;
        if (btn) {
          btn.disabled = true;
          btn.innerHTML = '<span class="material-symbols-outlined spinning">refresh</span> Generating...';
        }

        console.log('Generating report:', templateId, templateName, category);

        // Generate report ID
        const reportId = `RPT-${new Date().getFullYear()}-${Math.floor(Math.random() * 900000 + 100000)}`;

        // Generate report data
        const reportData = await generateReportData(templateId);
        console.log('Generated report data:', reportData);

        // Create report document
        const reportDoc = {
          reportId,
          templateId,
          title: `${templateName} - ${new Date().toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}`,
          type: category,
          status: 'completed',
          data: reportData,
          generatedAt: Timestamp.now(),
          generatedBy: user.email || user.uid,
          userId: user.uid,
        };

        console.log('Saving report to Firestore:', reportDoc);
        const docRef = await addDoc(collection(db, 'reports'), reportDoc);
        console.log('Report saved with ID:', docRef.id);

        alert(`Report ${reportId} generated successfully!`);
        
        // Reload reports
        await loadReports();

        // Reset button
        if (btn && originalText) {
          btn.disabled = false;
          btn.innerHTML = originalText;
        }
      } catch (error) {
        console.error('Error generating report:', error);
        alert('Failed to generate report: ' + (error instanceof Error ? error.message : 'Unknown error'));
        
        // Reset button
        const btn = (window.event?.target as HTMLElement)?.closest('button') as HTMLButtonElement;
        if (btn) {
          btn.disabled = false;
          btn.innerHTML = '<span class="material-symbols-outlined">add</span> Generate Report';
        }
      }
    };

    const renderTemplates = () => {
      const container = document.getElementById('templates-container')!;
      
      container.innerHTML = reportTemplates.map(template => `
        <div class="card template-card" style="cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;">
          <div class="card-body" style="display: flex; gap: 1rem;">
            <div style="width: 48px; height: 48px; border-radius: 0.625rem; background: var(--bg-secondary); display: flex; align-items: center; justify-content: center; color: var(--primary); flex-shrink: 0;">
              <span class="material-symbols-outlined" style="font-size: 28px;">${template.icon}</span>
            </div>
            <div style="flex: 1;">
              <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
                <h3 style="font-size: 1.125rem; font-weight: 600; margin: 0;">${template.name}</h3>
                <span class="badge badge-info" style="font-size: 0.625rem;">${template.category}</span>
              </div>
              <p style="font-size: 0.875rem; color: var(--text-secondary); margin: 0 0 1rem 0;">
                ${template.description}
              </p>
              <button class="btn btn-primary generate-btn" data-id="${template.id}" data-name="${template.name}" data-category="${template.category}" style="width: 100%;">
                <span class="material-symbols-outlined">add</span>
                Generate Report
              </button>
            </div>
          </div>
        </div>
      `).join('');

      // Add event listeners to generate buttons
      document.querySelectorAll('.generate-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          const templateId = target.getAttribute('data-id')!;
          const templateName = target.getAttribute('data-name')!;
          const category = target.getAttribute('data-category')!;
          generateReport(templateId, templateName, category);
        });
      });
    };

    const loadReports = async () => {
      try {
        // Query recent reports (last 30 days)
        const reportsRef = collection(db, 'reports');
        const thirtyDaysAgo = new Date();
        thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
        
        const reportsQuery = query(
          reportsRef,
          where('generatedAt', '>=', Timestamp.fromDate(thirtyDaysAgo)),
          orderBy('generatedAt', 'desc'),
          limit(20)
        );

        const reportsSnap = await getDocs(reportsQuery);
        
        const tbody = document.getElementById('reports-tbody')!;
        const noReports = document.getElementById('no-reports')!;
        const reportsCount = document.getElementById('reports-count')!;

        if (reportsSnap.empty) {
          tbody.innerHTML = '';
          noReports.classList.remove('hidden');
          reportsCount.textContent = '0 reports';
          return;
        }

        noReports.classList.add('hidden');
        reportsCount.textContent = `${reportsSnap.size} report${reportsSnap.size === 1 ? '' : 's'}`;

        const rows: string[] = [];

        reportsSnap.forEach(doc => {
          const data = doc.data();
          const generatedAt = data.generatedAt?.toDate() || new Date();
          
          rows.push(`
            <tr>
              <td>
                <div style="display: flex; align-items: center; gap: 0.5rem;">
                  <span class="material-symbols-outlined" style="color: var(--primary);">description</span>
                  <div>
                    <div style="font-weight: 600;">${data.title || 'Untitled Report'}</div>
                    <div style="font-size: 0.75rem; color: var(--text-secondary);">${data.reportId || doc.id}</div>
                  </div>
                </div>
              </td>
              <td>
                <span class="badge badge-info">${data.type || 'General'}</span>
              </td>
              <td style="font-size: 0.875rem; color: var(--text-secondary);">
                ${formatDateTime(generatedAt)}
              </td>
              <td style="font-size: 0.875rem;">${data.generatedBy || 'Unknown'}</td>
              <td>
                <div style="display: flex; gap: 0.5rem;">
                  <button class="btn-ghost view-report-btn" data-id="${doc.id}" style="padding: 0.5rem;" title="View report">
                    <span class="material-symbols-outlined" style="font-size: 20px;">visibility</span>
                  </button>
                  <button class="btn-ghost download-pdf-btn" data-id="${doc.id}" style="padding: 0.5rem;" title="Download PDF">
                    <span class="material-symbols-outlined" style="font-size: 20px;">download</span>
                  </button>
                  <button class="btn-ghost export-excel-btn" data-id="${doc.id}" style="padding: 0.5rem;" title="Export Excel">
                    <span class="material-symbols-outlined" style="font-size: 20px;">table_chart</span>
                  </button>
                </div>
              </td>
            </tr>
          `);
        });

        tbody.innerHTML = rows.join('');

        // Add event listeners to action buttons
        document.querySelectorAll('.view-report-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const reportId = (e.currentTarget as HTMLElement).getAttribute('data-id')!;
            viewReport(reportId);
          });
        });

        document.querySelectorAll('.download-pdf-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const reportId = (e.currentTarget as HTMLElement).getAttribute('data-id')!;
            downloadPDF(reportId);
          });
        });

        document.querySelectorAll('.export-excel-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const reportId = (e.currentTarget as HTMLElement).getAttribute('data-id')!;
            exportExcel(reportId);
          });
        });

      } catch (error) {
        console.error('Error loading reports:', error);
        const tbody = document.getElementById('reports-tbody')!;
        tbody.innerHTML = `
          <tr>
            <td colspan="5" style="text-align: center; padding: 2rem; color: #ef4444;">
              <span class="material-symbols-outlined" style="font-size: 32px;">error</span>
              <p style="margin-top: 0.5rem;">Error loading reports</p>
              <p style="font-size: 0.875rem;">${error instanceof Error ? error.message : 'Unknown error'}</p>
            </td>
          </tr>
        `;
      }
    };

    // View report in modal
    const viewReport = async (reportDocId: string) => {
      try {
        const reportDocRef = doc(db, 'reports', reportDocId);
        const reportSnap = await getDoc(reportDocRef);
        
        if (!reportSnap.exists()) {
          alert('Report not found');
          return;
        }

        let data = reportSnap.data();
        console.log('Viewing report - Full data:', JSON.stringify(data, null, 2));
        console.log('Has data field:', !!data.data);
        console.log('Template ID:', data.templateId);

        // If report doesn't have data, regenerate it
        if (!data.data && data.templateId) {
          console.log('Report missing data field, regenerating...');
          const regeneratedData = await generateReportData(data.templateId);
          if (regeneratedData) {
            data = { ...data, data: regeneratedData };
            console.log('Regenerated data:', regeneratedData);
          }
        }
        
        const modal = document.getElementById('report-modal')!;
        const modalTitle = document.getElementById('modal-title')!;
        const reportContent = document.getElementById('report-content')!;

        modalTitle.textContent = data.title || 'Report';

        // Render report based on template
        let html = '';

        if (data.templateId === 'sales-summary' && data.data) {
          const rd = data.data;
          console.log('Rendering sales report:', rd);
          html = `
            <div class="report-view">
              <div style="margin-bottom: 2rem;">
                <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem;">Report Summary</h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-top: 1rem;">
                  <div class="stat-box">
                    <div class="stat-label">Total Revenue</div>
                    <div class="stat-value">${formatCurrency(rd.summary.totalRevenue)}</div>
                  </div>
                  <div class="stat-box">
                    <div class="stat-label">Total Transactions</div>
                    <div class="stat-value">${rd.summary.totalTransactions}</div>
                  </div>
                  <div class="stat-box">
                    <div class="stat-label">Average Transaction</div>
                    <div class="stat-value">${formatCurrency(rd.summary.averageTransaction)}</div>
                  </div>
                </div>
              </div>

              ${rd.topProducts && rd.topProducts.length > 0 ? `
              <div style="margin-bottom: 2rem;">
                <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem;">Top Products</h3>
                <table class="report-table">
                  <thead>
                    <tr>
                      <th>SKU</th>
                      <th>Product Name</th>
                      <th>Quantity Sold</th>
                      <th>Revenue</th>
                    </tr>
                  </thead>
                  <tbody>
                    ${rd.topProducts.map((prod: any) => `
                      <tr>
                        <td>${prod.sku}</td>
                        <td>${prod.name}</td>
                        <td>${prod.quantity}</td>
                        <td>${formatCurrency(prod.revenue)}</td>
                      </tr>
                    `).join('')}
                  </tbody>
                </table>
              </div>
              ` : '<p style="color: var(--text-secondary);">No product sales data available.</p>'}

              ${rd.paymentMethods && Object.keys(rd.paymentMethods).length > 0 ? `
              <div style="margin-bottom: 2rem;">
                <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem;">Payment Methods</h3>
                <table class="report-table">
                  <thead>
                    <tr>
                      <th>Payment Method</th>
                      <th>Transaction Count</th>
                    </tr>
                  </thead>
                  <tbody>
                    ${Object.entries(rd.paymentMethods).map(([method, count]) => `
                      <tr>
                        <td>${method}</td>
                        <td>${count}</td>
                      </tr>
                    `).join('')}
                  </tbody>
                </table>
              </div>
              ` : ''}
            </div>
          `;
        } else if (data.templateId === 'inventory-status' && data.data) {
          const rd = data.data;
          console.log('Rendering inventory report:', rd);
          html = `
            <div class="report-view">
              <div style="margin-bottom: 2rem;">
                <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem;">Inventory Summary</h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-top: 1rem;">
                  <div class="stat-box">
                    <div class="stat-label">Total Value</div>
                    <div class="stat-value">${formatCurrency(rd.summary.totalValue)}</div>
                  </div>
                  <div class="stat-box">
                    <div class="stat-label">Total Items</div>
                    <div class="stat-value">${rd.summary.totalItems}</div>
                  </div>
                  <div class="stat-box">
                    <div class="stat-label">Low Stock Items</div>
                    <div class="stat-value">${rd.summary.lowStockItems}</div>
                  </div>
                  <div class="stat-box">
                    <div class="stat-label">Unique Products</div>
                    <div class="stat-value">${rd.summary.uniqueProducts}</div>
                  </div>
                </div>
              </div>

              ${rd.items && rd.items.length > 0 ? `
              <div style="margin-bottom: 2rem;">
                <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem;">Inventory Items</h3>
                <table class="report-table">
                  <thead>
                    <tr>
                      <th>SKU</th>
                      <th>Product Name</th>
                      <th>Quantity</th>
                      <th>Reorder Point</th>
                      <th>Unit Cost</th>
                      <th>Total Value</th>
                      <th>Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    ${rd.items.slice(0, 50).map((item: any) => `
                      <tr>
                        <td>${item.sku}</td>
                        <td>${item.name}</td>
                        <td>${item.quantity}</td>
                        <td>${item.reorderPoint}</td>
                        <td>${formatCurrency(item.cost)}</td>
                        <td>${formatCurrency(item.value)}</td>
                        <td><span class="badge ${item.status === 'Low Stock' ? 'badge-warning' : 'badge-success'}">${item.status}</span></td>
                      </tr>
                    `).join('')}
                  </tbody>
                </table>
                ${rd.items.length > 50 ? `<p style="margin-top: 1rem; font-size: 0.875rem; color: var(--text-secondary);">Showing top 50 items. Download full report for complete data.</p>` : ''}
              </div>
              ` : '<p style="color: var(--text-secondary);">No inventory data available.</p>'}
            </div>
          `;
        } else if (data.templateId === 'supplier-performance' && data.data) {
          const rd = data.data;
          console.log('Rendering supplier report:', rd);
          html = `
            <div class="report-view">
              <div style="margin-bottom: 2rem;">
                <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem;">Supplier Summary</h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-top: 1rem;">
                  <div class="stat-box">
                    <div class="stat-label">Total Suppliers</div>
                    <div class="stat-value">${rd.summary.totalSuppliers}</div>
                  </div>
                  <div class="stat-box">
                    <div class="stat-label">Active Suppliers</div>
                    <div class="stat-value">${rd.summary.activeSuppliers}</div>
                  </div>
                  <div class="stat-box">
                    <div class="stat-label">Total Pricelists</div>
                    <div class="stat-value">${rd.summary.totalPricelists}</div>
                  </div>
                </div>
              </div>

              ${rd.suppliers && rd.suppliers.length > 0 ? `
              <div style="margin-bottom: 2rem;">
                <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem;">Suppliers</h3>
                <table class="report-table">
                  <thead>
                    <tr>
                      <th>Supplier Name</th>
                      <th>Contact Person</th>
                      <th>Email</th>
                      <th>Phone</th>
                      <th>Pricelists</th>
                      <th>Last Update</th>
                      <th>Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    ${rd.suppliers.map((supplier: any) => `
                      <tr>
                        <td>${supplier.name}</td>
                        <td>${supplier.contactPerson}</td>
                        <td>${supplier.email}</td>
                        <td>${supplier.phone}</td>
                        <td>${supplier.pricelistCount}</td>
                        <td>${supplier.lastUpdate}</td>
                        <td><span class="badge ${supplier.status === 'Active' ? 'badge-success' : 'badge-secondary'}">${supplier.status}</span></td>
                      </tr>
                    `).join('')}
                  </tbody>
                </table>
              </div>
              ` : '<p style="color: var(--text-secondary);">No supplier data available.</p>'}
            </div>
          `;
        } else {
          console.warn('Report data structure:', data);
          html = `
            <div style="padding: 2rem; text-align: center; color: var(--text-secondary);">
              <p>Report data not available or unsupported format.</p>
              <p style="font-size: 0.875rem; margin-top: 0.5rem;">Template: ${data.templateId || 'Unknown'}</p>
              <p style="font-size: 0.875rem;">Has data: ${data.data ? 'Yes' : 'No'}</p>
            </div>
          `;
        }

        reportContent.innerHTML = html;
        modal.classList.remove('hidden');

        // Store current report ID for export functions
        (window as any).currentReportId = reportDocId;

      } catch (error) {
        console.error('Error viewing report:', error);
        alert('Failed to load report. Please try again.');
      }
    };

    // Download PDF
    const downloadPDF = async (reportDocId: string) => {
      try {
        const reportDocRef = doc(db, 'reports', reportDocId);
        const reportSnap = await getDoc(reportDocRef);
        
        if (!reportSnap.exists()) {
          alert('Report not found');
          return;
        }

        let data = reportSnap.data();
        console.log('Exporting PDF for report:', data);

        // If report doesn't have data, regenerate it
        if (!data.data && data.templateId) {
          console.log('Report missing data field, regenerating for PDF...');
          const regeneratedData = await generateReportData(data.templateId);
          if (regeneratedData) {
            data = { ...data, data: regeneratedData };
          }
        }
        
        // Create a simple HTML page for printing
        const printWindow = window.open('', '_blank');
        if (!printWindow) {
          alert('Please allow popups to download PDF');
          return;
        }

        let content = '';
        
        if (data.templateId === 'sales-summary' && data.data) {
          const rd = data.data;
          content = `
            <h2>Sales Summary Report</h2>
            <p><strong>Report ID:</strong> ${data.reportId}</p>
            <p><strong>Generated:</strong> ${formatDateTime(data.generatedAt?.toDate())}</p>
            <p><strong>Generated By:</strong> ${data.generatedBy}</p>
            
            <h3>Summary</h3>
            <table>
              <tr><td>Total Revenue:</td><td>${formatCurrency(rd.summary.totalRevenue)}</td></tr>
              <tr><td>Total Transactions:</td><td>${rd.summary.totalTransactions}</td></tr>
              <tr><td>Average Transaction:</td><td>${formatCurrency(rd.summary.averageTransaction)}</td></tr>
            </table>

            <h3>Top Products</h3>
            <table border="1" cellpadding="8" cellspacing="0" style="border-collapse: collapse; width: 100%;">
              <thead>
                <tr><th>SKU</th><th>Product Name</th><th>Quantity</th><th>Revenue</th></tr>
              </thead>
              <tbody>
                ${rd.topProducts.map((prod: any) => `
                  <tr><td>${prod.sku}</td><td>${prod.name}</td><td>${prod.quantity}</td><td>${formatCurrency(prod.revenue)}</td></tr>
                `).join('')}
              </tbody>
            </table>

            <h3>Payment Methods</h3>
            <table border="1" cellpadding="8" cellspacing="0" style="border-collapse: collapse;">
              <thead>
                <tr><th>Payment Method</th><th>Count</th></tr>
              </thead>
              <tbody>
                ${Object.entries(rd.paymentMethods).map(([method, count]) => `
                  <tr><td>${method}</td><td>${count}</td></tr>
                `).join('')}
              </tbody>
            </table>
          `;
        } else if (data.templateId === 'inventory-status' && data.data) {
          const rd = data.data;
          content = `
            <h2>Inventory Status Report</h2>
            <p><strong>Report ID:</strong> ${data.reportId}</p>
            <p><strong>Generated:</strong> ${formatDateTime(data.generatedAt?.toDate())}</p>
            
            <h3>Summary</h3>
            <table>
              <tr><td>Total Value:</td><td>${formatCurrency(rd.summary.totalValue)}</td></tr>
              <tr><td>Total Items:</td><td>${rd.summary.totalItems}</td></tr>
              <tr><td>Low Stock Items:</td><td>${rd.summary.lowStockItems}</td></tr>
              <tr><td>Unique Products:</td><td>${rd.summary.uniqueProducts}</td></tr>
            </table>

            <h3>Inventory Items</h3>
            <table border="1" cellpadding="8" cellspacing="0" style="border-collapse: collapse; width: 100%; font-size: 12px;">
              <thead>
                <tr><th>SKU</th><th>Name</th><th>Qty</th><th>Reorder</th><th>Cost</th><th>Value</th><th>Status</th></tr>
              </thead>
              <tbody>
                ${rd.items.map((item: any) => `
                  <tr><td>${item.sku}</td><td>${item.name}</td><td>${item.quantity}</td><td>${item.reorderPoint}</td><td>${formatCurrency(item.cost)}</td><td>${formatCurrency(item.value)}</td><td>${item.status}</td></tr>
                `).join('')}
              </tbody>
            </table>
          `;
        } else if (data.templateId === 'supplier-performance' && data.data) {
          const rd = data.data;
          content = `
            <h2>Supplier Performance Report</h2>
            <p><strong>Report ID:</strong> ${data.reportId}</p>
            <p><strong>Generated:</strong> ${formatDateTime(data.generatedAt?.toDate())}</p>
            
            <h3>Summary</h3>
            <table>
              <tr><td>Total Suppliers:</td><td>${rd.summary.totalSuppliers}</td></tr>
              <tr><td>Active Suppliers:</td><td>${rd.summary.activeSuppliers}</td></tr>
              <tr><td>Total Pricelists:</td><td>${rd.summary.totalPricelists}</td></tr>
            </table>

            <h3>Suppliers</h3>
            <table border="1" cellpadding="8" cellspacing="0" style="border-collapse: collapse; width: 100%; font-size: 12px;">
              <thead>
                <tr><th>Name</th><th>Contact</th><th>Email</th><th>Phone</th><th>Pricelists</th><th>Last Update</th><th>Status</th></tr>
              </thead>
              <tbody>
                ${rd.suppliers.map((s: any) => `
                  <tr><td>${s.name}</td><td>${s.contactPerson}</td><td>${s.email}</td><td>${s.phone}</td><td>${s.pricelistCount}</td><td>${s.lastUpdate}</td><td>${s.status}</td></tr>
                `).join('')}
              </tbody>
            </table>
          `;
        }

        printWindow.document.write(`
          <!DOCTYPE html>
          <html>
          <head>
            <title>${data.title}</title>
            <style>
              body { font-family: Arial, sans-serif; padding: 20px; }
              h2 { color: #333; margin-bottom: 10px; }
              h3 { color: #666; margin-top: 30px; margin-bottom: 15px; }
              table { margin-top: 10px; margin-bottom: 20px; }
              table td:first-child { font-weight: bold; padding-right: 20px; }
              @media print { button { display: none; } }
            </style>
          </head>
          <body>
            ${content}
            <button onclick="window.print()" style="margin-top: 20px; padding: 10px 20px; background: #4F46E5; color: white; border: none; border-radius: 5px; cursor: pointer;">Print / Save as PDF</button>
          </body>
          </html>
        `);
        printWindow.document.close();

      } catch (error) {
        console.error('Error downloading PDF:', error);
        alert('Failed to generate PDF. Please try again.');
      }
    };

    // Export to Excel (CSV format)
    const exportExcel = async (reportDocId: string) => {
      try {
        const reportDocRef = doc(db, 'reports', reportDocId);
        const reportSnap = await getDoc(reportDocRef);
        
        if (!reportSnap.exists()) {
          alert('Report not found');
          return;
        }

        let data = reportSnap.data();
        console.log('Exporting Excel for report:', data);

        // If report doesn't have data, regenerate it
        if (!data.data && data.templateId) {
          console.log('Report missing data field, regenerating for Excel...');
          const regeneratedData = await generateReportData(data.templateId);
          if (regeneratedData) {
            data = { ...data, data: regeneratedData };
          }
        }
        let csv = '';
        let filename = `${data.reportId || 'report'}.csv`;

        if (data.templateId === 'sales-summary' && data.data) {
          const rd = data.data;
          csv = `Sales Summary Report\n`;
          csv += `Report ID,${data.reportId}\n`;
          csv += `Generated,${formatDateTime(data.generatedAt?.toDate())}\n\n`;
          
          csv += `Summary\n`;
          csv += `Total Revenue,${rd.summary.totalRevenue}\n`;
          csv += `Total Transactions,${rd.summary.totalTransactions}\n`;
          csv += `Average Transaction,${rd.summary.averageTransaction}\n\n`;
          
          csv += `Top Products\n`;
          csv += `SKU,Product Name,Quantity Sold,Revenue\n`;
          rd.topProducts.forEach((prod: any) => {
            csv += `${prod.sku},"${prod.name}",${prod.quantity},${prod.revenue}\n`;
          });
          
          csv += `\nPayment Methods\n`;
          csv += `Payment Method,Transaction Count\n`;
          Object.entries(rd.paymentMethods).forEach(([method, count]) => {
            csv += `${method},${count}\n`;
          });
        } else if (data.templateId === 'inventory-status' && data.data) {
          const rd = data.data;
          csv = `Inventory Status Report\n`;
          csv += `Report ID,${data.reportId}\n`;
          csv += `Generated,${formatDateTime(data.generatedAt?.toDate())}\n\n`;
          
          csv += `Summary\n`;
          csv += `Total Value,${rd.summary.totalValue}\n`;
          csv += `Total Items,${rd.summary.totalItems}\n`;
          csv += `Low Stock Items,${rd.summary.lowStockItems}\n`;
          csv += `Unique Products,${rd.summary.uniqueProducts}\n\n`;
          
          csv += `Inventory Items\n`;
          csv += `SKU,Product Name,Quantity,Reorder Point,Unit Cost,Total Value,Status\n`;
          rd.items.forEach((item: any) => {
            csv += `${item.sku},"${item.name}",${item.quantity},${item.reorderPoint},${item.cost},${item.value},${item.status}\n`;
          });
        } else if (data.templateId === 'supplier-performance' && data.data) {
          const rd = data.data;
          csv = `Supplier Performance Report\n`;
          csv += `Report ID,${data.reportId}\n`;
          csv += `Generated,${formatDateTime(data.generatedAt?.toDate())}\n\n`;
          
          csv += `Summary\n`;
          csv += `Total Suppliers,${rd.summary.totalSuppliers}\n`;
          csv += `Active Suppliers,${rd.summary.activeSuppliers}\n`;
          csv += `Total Pricelists,${rd.summary.totalPricelists}\n\n`;
          
          csv += `Suppliers\n`;
          csv += `Name,Contact Person,Email,Phone,Pricelists,Last Update,Status\n`;
          rd.suppliers.forEach((s: any) => {
            csv += `"${s.name}","${s.contactPerson}","${s.email}",${s.phone},${s.pricelistCount},${s.lastUpdate},${s.status}\n`;
          });
        }

        // Download CSV
        const blob = new Blob([csv], { type: 'text/csv' });
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        a.click();
        window.URL.revokeObjectURL(url);

      } catch (error) {
        console.error('Error exporting Excel:', error);
        alert('Failed to export to Excel. Please try again.');
      }
    };

    const loadPage = async () => {
      try {
        // Render templates (static)
        renderTemplates();

        // Load reports from Firestore
        await loadReports();

        // Show content, hide loading
        loadingState.classList.add('hidden');
        reportsContent.classList.remove('hidden');

      } catch (error) {
        console.error('Error loading page:', error);
        loadingState.innerHTML = `
          <span class="material-symbols-outlined" style="font-size: 48px; color: #ef4444;">error</span>
          <p style="margin-top: 1rem; color: #ef4444;">Error loading reports page</p>
          <p style="font-size: 0.875rem; color: var(--text-secondary);">${error instanceof Error ? error.message : 'Unknown error'}</p>
        `;
      }
    };

    // Load page on mount
    loadPage();

    // Modal close handlers
    document.getElementById('close-modal')?.addEventListener('click', () => {
      document.getElementById('report-modal')?.classList.add('hidden');
    });

    document.getElementById('modal-close-btn')?.addEventListener('click', () => {
      document.getElementById('report-modal')?.classList.add('hidden');
    });

    document.getElementById('report-modal')?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).id === 'report-modal') {
        document.getElementById('report-modal')?.classList.add('hidden');
      }
    });

    // Modal export buttons
    document.getElementById('modal-download-pdf')?.addEventListener('click', () => {
      const reportId = (window as any).currentReportId;
      if (reportId) downloadPDF(reportId);
    });

    document.getElementById('modal-export-excel')?.addEventListener('click', () => {
      const reportId = (window as any).currentReportId;
      if (reportId) exportExcel(reportId);
    });
  </script>

  <style>
    .loading-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 4rem 2rem;
    }

    .spinner {
      width: 48px;
      height: 48px;
      border: 4px solid #e5e7eb;
      border-top-color: var(--primary);
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .spinning {
      animation: spin 1s linear infinite;
    }

    .hidden {
      display: none !important;
    }

    .template-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
    }

    /* Modal styles */
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      padding: 1rem;
    }

    .modal-container {
      background: var(--bg-primary);
      border-radius: 0.75rem;
      box-shadow: var(--shadow-xl);
      width: 100%;
      max-height: 90vh;
      display: flex;
      flex-direction: column;
    }

    .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem;
      border-bottom: 1px solid var(--border-color);
    }

    .modal-header h2 {
      font-size: 1.25rem;
      font-weight: 600;
      margin: 0;
    }

    .modal-body {
      padding: 1.5rem;
      overflow-y: auto;
    }

    .modal-footer {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.75rem;
      padding: 1.5rem;
      border-top: 1px solid var(--border-color);
    }

    /* Report view styles */
    .report-view {
      color: var(--text-primary);
    }

    .stat-box {
      background: var(--bg-secondary);
      padding: 1rem;
      border-radius: 0.625rem;
      border: 1px solid var(--border-color);
    }

    .stat-label {
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-bottom: 0.5rem;
    }

    .stat-value {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .report-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
    }

    .report-table th {
      background: var(--bg-secondary);
      padding: 0.75rem;
      text-align: left;
      font-weight: 600;
      font-size: 0.875rem;
      border: 1px solid var(--border-color);
    }

    .report-table td {
      padding: 0.75rem;
      border: 1px solid var(--border-color);
      font-size: 0.875rem;
    }

    .report-table tbody tr:hover {
      background: var(--bg-secondary);
    }
  </style>
</ModernLayout>
