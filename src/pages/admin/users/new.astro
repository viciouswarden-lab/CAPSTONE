---
/**
 * Create New User Page - Firestore Connected
 * 
 * Form to create a new user account and save to Firestore + Firebase Auth.
 */

import ModernLayout from '../../../layouts/ModernLayout.astro';

const pageTitle = 'Create New User';
---

<ModernLayout title={pageTitle} requireAuth={true}>
  <div class="user-form-page">
    <!-- Header -->
    <div class="page-header">
      <div>
        <a href="/admin/users" class="back-link">← Back to Users</a>
        <h1>👤 Create New User</h1>
        <p class="subtitle">Add a new user account with role assignment</p>
      </div>
    </div>

    <!-- Firestore Status Notice -->
    <div class="demo-notice">
      <strong>🔥 Connected to Firestore:</strong> When you submit this form, the user account will be created in Firebase Auth and user details saved to Firestore immediately.
    </div>

    <!-- Success/Error Message -->
    <div id="message-container" class="hidden"></div>

    <!-- User Form -->
    <div class="card">
      <form id="user-form" class="user-form">
        <!-- Basic Information -->
        <div class="form-section">
          <h3>📋 Account Information</h3>
          
          <div class="form-group">
            <label for="email">
              Email Address <span class="required">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="e.g., user@tpro.com"
            />
            <small>Used for login and notifications</small>
          </div>

          <div class="form-group">
            <label for="displayName">
              Display Name <span class="required">*</span>
            </label>
            <input
              type="text"
              id="displayName"
              name="displayName"
              required
              placeholder="e.g., Juan Dela Cruz"
            />
            <small>Name shown in the system</small>
          </div>

          <div class="form-group">
            <label for="password">
              Initial Password <span class="required">*</span>
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              placeholder="Minimum 6 characters"
              minlength="6"
            />
            <small>User can change this after first login</small>
          </div>
        </div>

        <!-- Role Assignment -->
        <div class="form-section">
          <h3>🔐 Role & Permissions</h3>
          
          <div class="form-group">
            <label for="role">
              User Role <span class="required">*</span>
            </label>
            <select id="role" name="role" required>
              <option value="">Select role...</option>
              <option value="Administrator">Administrator - Full system access</option>
              <option value="Manager">Manager - Manage operations and reports</option>
              <option value="Analyst">Analyst - Pricelists and matching</option>
              <option value="Clerk">Clerk - Pricelists and inventory</option>
              <option value="Sales_Associate">Sales Associate - POS only</option>
            </select>
            <small>Role determines what features the user can access</small>
          </div>

          <!-- Role Permissions Display -->
          <div id="permissions-display" class="permissions-display hidden">
            <strong>Permissions granted:</strong>
            <ul id="permissions-list" class="permissions-list"></ul>
          </div>
        </div>

        <!-- Form Actions -->
        <div class="form-actions">
          <a href="/admin/users" class="btn-secondary">Cancel</a>
          <button type="submit" class="btn-primary" id="submit-btn">
            ✅ Create User
          </button>
        </div>
      </form>
    </div>
  </div>
</ModernLayout>

<script>
  import { userManagementService } from '../../../services/users/UserManagementService';
  import type { CreateUserData } from '../../../services/users/UserManagementService';
  import type { UserRole } from '../../../types/models';

  const form = document.getElementById('user-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const messageContainer = document.getElementById('message-container') as HTMLDivElement;
  const roleSelect = document.getElementById('role') as HTMLSelectElement;
  const permissionsDisplay = document.getElementById('permissions-display')!;
  const permissionsList = document.getElementById('permissions-list')!;

  // Role permissions mapping
  const rolePermissions: Record<string, string[]> = {
    'Administrator': [
      'Manage users',
      'Manage suppliers',
      'Upload pricelists',
      'Approve matches',
      'Adjust inventory',
      'Process sales',
      'Generate reports'
    ],
    'Manager': [
      'Manage suppliers',
      'Upload pricelists',
      'Approve matches',
      'Adjust inventory',
      'Process sales',
      'Generate reports'
    ],
    'Analyst': [
      'Upload pricelists',
      'Approve matches',
      'Generate reports'
    ],
    'Clerk': [
      'Upload pricelists',
      'Adjust inventory'
    ],
    'Sales_Associate': [
      'Process sales'
    ]
  };

  // Update permissions display when role changes
  roleSelect.addEventListener('change', () => {
    const selectedRole = roleSelect.value;
    
    if (selectedRole && rolePermissions[selectedRole]) {
      permissionsList.innerHTML = '';
      rolePermissions[selectedRole].forEach(permission => {
        const li = document.createElement('li');
        li.innerHTML = `<span class="material-symbols-outlined" style="font-size: 16px; color: #10b981;">check_circle</span> ${permission}`;
        permissionsList.appendChild(li);
      });
      permissionsDisplay.classList.remove('hidden');
    } else {
      permissionsDisplay.classList.add('hidden');
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Disable submit button
    submitBtn.disabled = true;
    submitBtn.textContent = '⏳ Creating...';

    // Get form data
    const formData = new FormData(form);
    const userData: CreateUserData = {
      email: formData.get('email')?.toString() || '',
      displayName: formData.get('displayName')?.toString() || '',
      role: formData.get('role')?.toString() as UserRole,
      password: formData.get('password')?.toString() || '',
    };

    try {
      // Validate required fields
      if (!userData.email || !userData.displayName || !userData.role || !userData.password) {
        throw new Error('All required fields must be filled');
      }

      if (userData.password.length < 6) {
        throw new Error('Password must be at least 6 characters long');
      }

      // Create user
      const userId = await userManagementService.createUser(userData);

      // Show success message
      messageContainer.className = 'alert-success';
      messageContainer.innerHTML = `
        ✅ User account "${userData.displayName}" created successfully!
        <div style="margin-top: 1rem;">
          <strong>User ID:</strong> ${userId}<br>
          <strong>Email:</strong> ${userData.email}<br>
          <strong>Role:</strong> ${userData.role}
        </div>
        <div style="margin-top: 1rem; display: flex; gap: 1rem;">
          <a href="/admin/users" class="btn-secondary">← Back to Users</a>
          <button onclick="location.reload()" class="btn-primary">Create Another User</button>
        </div>
      `;
      messageContainer.classList.remove('hidden');

      // Reset form
      form.reset();
      permissionsDisplay.classList.add('hidden');

      // Scroll to top to show success message
      window.scrollTo({ top: 0, behavior: 'smooth' });

    } catch (error) {
      // Show error message
      const errorMessage = error instanceof Error ? error.message : 'Failed to create user';
      
      messageContainer.className = 'alert-error';
      messageContainer.innerHTML = `
        ❌ ${errorMessage}
      `;
      messageContainer.classList.remove('hidden');

      // Re-enable submit button
      submitBtn.disabled = false;
      submitBtn.innerHTML = '✅ Create User';

      // Scroll to top to show error message
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });
</script>

<style>
  .user-form-page {
    padding: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-block;
    color: #2563eb;
    text-decoration: none;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .page-header h1 {
    font-size: 2rem;
    color: #111827;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: #6b7280;
    font-size: 1rem;
  }

  .demo-notice {
    background: linear-gradient(135deg, #dbeafe 0%, #e0e7ff 100%);
    border: 2px solid #3b82f6;
    border-radius: 0.75rem;
    padding: 1rem 1.5rem;
    margin-bottom: 2rem;
    color: #1e40af;
    font-size: 0.875rem;
  }

  .alert-success {
    background: #d1fae5;
    border: 2px solid #10b981;
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
    color: #065f46;
  }

  .alert-error {
    background: #fee2e2;
    border: 2px solid #ef4444;
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
    color: #991b1b;
  }

  .hidden {
    display: none;
  }

  .card {
    background: white;
    border-radius: 0.75rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    padding: 2rem;
  }

  .user-form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .form-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-section h3 {
    font-size: 1.125rem;
    color: #111827;
    margin-bottom: 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
  }

  .required {
    color: #ef4444;
  }

  input[type="text"],
  input[type="email"],
  input[type="password"],
  select {
    padding: 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    transition: all 0.2s;
  }

  input:focus,
  select:focus {
    outline: none;
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  small {
    font-size: 0.75rem;
    color: #6b7280;
  }

  .permissions-display {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    padding: 1rem;
    margin-top: 0.5rem;
  }

  .permissions-list {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .permissions-list li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #374151;
  }

  .form-actions {
    display: flex;
    gap: 1rem;
    justify-content: flex-end;
    padding-top: 1rem;
    border-top: 1px solid #e5e7eb;
  }

  .btn-primary {
    padding: 0.75rem 2rem;
    background-color: #2563eb;
    color: white;
    border: none;
    border-radius: 0.5rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-primary:hover:not(:disabled) {
    background-color: #1d4ed8;
    transform: translateY(-1px);
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
  }

  .btn-primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .btn-secondary {
    padding: 0.75rem 2rem;
    background-color: white;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 0.5rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s;
    display: inline-block;
    text-align: center;
  }

  .btn-secondary:hover {
    background-color: #f9fafb;
    border-color: #9ca3af;
  }

  @media (max-width: 768px) {
    .user-form-page {
      padding: 1rem;
    }

    .form-actions {
      flex-direction: column-reverse;
    }

    .btn-primary,
    .btn-secondary {
      width: 100%;
    }
  }
</style>
