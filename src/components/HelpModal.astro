---
/**
 * Help Modal Component
 * 
 * Displays keyboard shortcuts documentation in a modal dialog.
 * Validates Requirement 20.4
 * 
 * This modal is triggered by the Shift+? keyboard shortcut and displays
 * all available keyboard shortcuts organized by category.
 */

import Modal from './Modal.astro';
---

<div id="keyboard-shortcuts-modal">
  <Modal title="Keyboard Shortcuts" size="lg" closable={true}>
    <div class="keyboard-shortcuts-content">
      <p class="text-gray-600 mb-6">
        Use these keyboard shortcuts to navigate and perform actions quickly throughout the system.
      </p>

      <!-- Navigation Shortcuts -->
      <div class="shortcut-category mb-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-3 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
          </svg>
          Navigation
        </h3>
        <div class="shortcut-list space-y-2" data-category="navigation">
          <!-- Populated by JavaScript -->
        </div>
      </div>

      <!-- Action Shortcuts -->
      <div class="shortcut-category mb-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-3 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Actions
        </h3>
        <div class="shortcut-list space-y-2" data-category="actions">
          <!-- Populated by JavaScript -->
        </div>
      </div>

      <!-- Form Shortcuts -->
      <div class="shortcut-category mb-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-3 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Forms
        </h3>
        <div class="shortcut-list space-y-2" data-category="forms">
          <!-- Populated by JavaScript -->
        </div>
      </div>

      <!-- General Shortcuts -->
      <div class="shortcut-category">
        <h3 class="text-lg font-semibold text-gray-900 mb-3 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
          </svg>
          General
        </h3>
        <div class="shortcut-list space-y-2" data-category="general">
          <!-- Populated by JavaScript -->
        </div>
      </div>
    </div>

    <div slot="footer" class="w-full flex justify-between items-center">
      <p class="text-sm text-gray-500">
        Press <kbd class="kbd-style">Shift</kbd> + <kbd class="kbd-style">?</kbd> or <kbd class="kbd-style">F1</kbd> to toggle this help
      </p>
      <button
        type="button"
        class="btn-cancel px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors"
      >
        Close
      </button>
    </div>
  </Modal>
</div>

<style>
  .shortcut-list {
    display: flex;
    flex-direction: column;
  }

  .shortcut-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: #f9fafb;
    border-radius: 0.375rem;
    transition: background-color 0.2s;
  }

  .shortcut-item:hover {
    background: #f3f4f6;
  }

  .shortcut-description {
    color: #374151;
    font-size: 0.875rem;
  }

  .shortcut-keys {
    display: flex;
    gap: 0.25rem;
    align-items: center;
  }

  .kbd-style {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: #1f2937;
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 0.25rem;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  }

  .shortcut-category {
    border-left: 3px solid #3b82f6;
    padding-left: 1rem;
  }

  /* Empty state */
  .shortcut-list:empty::after {
    content: 'No shortcuts available';
    display: block;
    color: #9ca3af;
    font-size: 0.875rem;
    font-style: italic;
    padding: 0.5rem 0;
  }

  /* Mobile responsive */
  @media (max-width: 640px) {
    .shortcut-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>

<script>
  /**
   * Populate keyboard shortcuts in the help modal
   * Dynamically loads shortcuts from the KeyboardShortcutManager
   */
  
  import { keyboardShortcuts } from '../utils/keyboardShortcuts';

  function populateShortcuts() {
    const grouped = keyboardShortcuts.getShortcutsByCategory();
    
    // Populate each category
    Object.entries(grouped).forEach(([category, shortcuts]) => {
      const container = document.querySelector<HTMLElement>(
        `.shortcut-list[data-category="${category}"]`
      );
      
      if (!container) return;
      
      // Clear existing content
      container.innerHTML = '';
      
      // Add each shortcut
      shortcuts.forEach(shortcut => {
        const item = document.createElement('div');
        item.className = 'shortcut-item';
        
        const description = document.createElement('span');
        description.className = 'shortcut-description';
        description.textContent = shortcut.description;
        
        const keys = document.createElement('div');
        keys.className = 'shortcut-keys';
        
        const formattedKeys = keyboardShortcuts.formatShortcut(shortcut);
        formattedKeys.split(' + ').forEach((key, index) => {
          if (index > 0) {
            const plus = document.createElement('span');
            plus.textContent = '+';
            plus.className = 'text-gray-400 text-xs';
            keys.appendChild(plus);
          }
          
          const kbd = document.createElement('kbd');
          kbd.className = 'kbd-style';
          kbd.textContent = key;
          keys.appendChild(kbd);
        });
        
        item.appendChild(description);
        item.appendChild(keys);
        container.appendChild(item);
      });
    });
  }

  // Populate shortcuts when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    populateShortcuts();
    
    // Re-populate if shortcuts are dynamically registered
    document.addEventListener('shortcuts-updated', () => {
      populateShortcuts();
    });
  });

  // Also populate immediately if DOM is already loaded
  if (document.readyState !== 'loading') {
    populateShortcuts();
  }
</script>
