---
/**
 * User Create/Edit Page
 * 
 * Administrator-only page for creating new user accounts and editing existing users.
 * Supports role assignment, activation/deactivation, and password management.
 * 
 * Requirements: 16.1, 16.2, 16.3, 16.5
 * Task: 34.2
 */

import MainLayout from '../../../layouts/MainLayout.astro';
import ErrorMessage from '../../../components/ErrorMessage.astro';
import LoadingSpinner from '../../../components/LoadingSpinner.astro';
import { userManagementService } from '../../../services/users/UserManagementService';
import type { User, UserRole } from '../../../types/models';

// For CAPSTONE demo static build: provide empty static paths
export function getStaticPaths() {
  return [];
}

// Get user ID from URL
const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/users');
}

// Check if this is a create or edit operation
const isCreateMode = id === 'new';

// Fetch user data if editing
let user: User | null = null;
let error: string | null = null;
let loading = !isCreateMode;

if (!isCreateMode) {
  try {
    user = await userManagementService.getUser(id);
    loading = false;
    
    if (!user) {
      error = 'User not found';
    }
  } catch (e) {
    loading = false;
    error = e instanceof Error ? e.message : 'Failed to load user';
  }
}

// Format dates for display
const formatDate = (date: Date): string => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  }).format(date);
};

// Role options with descriptions
const roleOptions: { value: UserRole; label: string; description: string }[] = [
  {
    value: 'Administrator',
    label: 'Administrator',
    description: 'Full system access including user management'
  },
  {
    value: 'Manager',
    label: 'Manager',
    description: 'Manage suppliers, inventory, and generate reports'
  },
  {
    value: 'Analyst',
    label: 'Analyst',
    description: 'Upload pricelists, approve matches, and generate reports'
  },
  {
    value: 'Clerk',
    label: 'Clerk',
    description: 'Upload pricelists and adjust inventory'
  },
  {
    value: 'Sales_Associate',
    label: 'Sales Associate',
    description: 'Process sales transactions'
  }
];

const pageTitle = isCreateMode ? 'Create New User' : `Edit User: ${user?.displayName || ''}`;
---

<MainLayout title={pageTitle} requireAuth={true} requiredRole="Administrator">
  <div class="user-form-page">
    <!-- Page Header -->
    <div class="page-header mb-6">
      <div class="flex items-center justify-between">
        <div>
          <a href="/admin/users" class="back-link text-blue-600 hover:text-blue-800 flex items-center gap-1 mb-2">
            <span>←</span>
            <span>Back to Users</span>
          </a>
          <h1 class="text-3xl font-bold">
            {isCreateMode ? '➕ Create New User' : `✎ Edit User: ${user?.displayName || ''}`}
          </h1>
          {!isCreateMode && user && (
            <span class={`status-badge inline-block mt-2 px-3 py-1 rounded-full text-sm font-medium ${user.isActive ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>
              {user.isActive ? 'Active' : 'Inactive'}
            </span>
          )}
        </div>
      </div>
    </div>

    <!-- Error Display -->
    {error && (
      <ErrorMessage message={error} type="error" />
    )}

    <!-- Loading State -->
    {loading && (
      <LoadingSpinner message="Loading user details..." />
    )}

    <!-- User Form -->
    {(isCreateMode || (user && !loading)) && (
      <div class="user-content grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Content - Form -->
        <div class="lg:col-span-2">
          <div class="card bg-white rounded-lg shadow p-6">
            <h2 class="text-xl font-semibold mb-6">
              {isCreateMode ? 'User Information' : 'Edit User Information'}
            </h2>

            <form id="user-form" data-mode={isCreateMode ? 'create' : 'edit'} data-user-id={user?.userId}>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Email -->
                <div class="form-group md:col-span-2">
                  <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
                    Email Address <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    value={user?.email || ''}
                    required
                    disabled={!isCreateMode}
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 disabled:bg-gray-100 disabled:cursor-not-allowed"
                    placeholder="user@example.com"
                  />
                  {!isCreateMode && (
                    <p class="text-xs text-gray-500 mt-1">Email cannot be changed after account creation</p>
                  )}
                  <div id="email-error" class="field-error hidden"></div>
                </div>

                <!-- Display Name -->
                <div class="form-group md:col-span-2">
                  <label for="displayName" class="block text-sm font-medium text-gray-700 mb-1">
                    Display Name <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="text"
                    id="displayName"
                    name="displayName"
                    value={user?.displayName || ''}
                    required
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="John Doe"
                  />
                  <div id="displayName-error" class="field-error hidden"></div>
                </div>

                <!-- Role -->
                <div class="form-group md:col-span-2">
                  <label for="role" class="block text-sm font-medium text-gray-700 mb-1">
                    Role <span class="text-red-500">*</span>
                  </label>
                  <select
                    id="role"
                    name="role"
                    required
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                  >
                    <option value="">Select a role...</option>
                    {roleOptions.map(option => (
                      <option 
                        value={option.value}
                        selected={user?.role === option.value}
                      >
                        {option.label}
                      </option>
                    ))}
                  </select>
                  <div id="role-description" class="text-xs text-gray-600 mt-1 italic"></div>
                  <div id="role-error" class="field-error hidden"></div>
                </div>

                <!-- Password (Create mode only) -->
                {isCreateMode && (
                  <>
                    <div class="form-group">
                      <label for="password" class="block text-sm font-medium text-gray-700 mb-1">
                        Initial Password <span class="text-red-500">*</span>
                      </label>
                      <input
                        type="password"
                        id="password"
                        name="password"
                        required
                        minlength="6"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                        placeholder="Minimum 6 characters"
                      />
                      <div id="password-error" class="field-error hidden"></div>
                    </div>

                    <div class="form-group">
                      <label for="confirmPassword" class="block text-sm font-medium text-gray-700 mb-1">
                        Confirm Password <span class="text-red-500">*</span>
                      </label>
                      <input
                        type="password"
                        id="confirmPassword"
                        name="confirmPassword"
                        required
                        minlength="6"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                        placeholder="Re-enter password"
                      />
                      <div id="confirmPassword-error" class="field-error hidden"></div>
                    </div>
                  </>
                )}

                <!-- Active Status (Edit mode only) -->
                {!isCreateMode && (
                  <div class="form-group md:col-span-2">
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input
                        type="checkbox"
                        id="isActive"
                        name="isActive"
                        checked={user?.isActive}
                        class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500"
                      />
                      <span class="text-sm font-medium text-gray-700">
                        Account Active
                      </span>
                    </label>
                    <p class="text-xs text-gray-500 mt-1 ml-6">
                      Deactivating an account prevents login while preserving audit trail
                    </p>
                  </div>
                )}
              </div>

              <div id="form-error" class="mt-4 hidden"></div>
              <div id="form-success" class="mt-4 hidden"></div>

              <div class="form-actions mt-6 flex gap-3 justify-end">
                <a
                  href="/admin/users"
                  class="btn-cancel px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition-colors"
                >
                  Cancel
                </a>
                <button
                  type="submit"
                  id="save-btn"
                  class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors font-medium"
                >
                  {isCreateMode ? 'Create User' : 'Save Changes'}
                </button>
              </div>
            </form>
          </div>
        </div>

        <!-- Sidebar - Information -->
        <div class="lg:col-span-1">
          {isCreateMode ? (
            <!-- Create Mode - Role Permissions Info -->
            <div class="card bg-white rounded-lg shadow p-6">
              <h3 class="text-lg font-semibold mb-4">Role Descriptions</h3>
              <div class="space-y-4">
                {roleOptions.map(role => (
                  <div class="role-info">
                    <h4 class="text-sm font-semibold text-gray-900">{role.label}</h4>
                    <p class="text-xs text-gray-600 mt-1">{role.description}</p>
                  </div>
                ))}
              </div>
            </div>
          ) : (
            <!-- Edit Mode - Metadata -->
            <div class="card bg-white rounded-lg shadow p-6">
              <h3 class="text-lg font-semibold mb-4">User Metadata</h3>
              <dl class="space-y-3">
                <div>
                  <dt class="text-sm font-medium text-gray-500">User ID</dt>
                  <dd class="mt-1 text-sm text-gray-900 font-mono break-all">{user?.userId}</dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Created</dt>
                  <dd class="mt-1 text-sm text-gray-900">{formatDate(user!.createdAt)}</dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Last Login</dt>
                  <dd class="mt-1 text-sm text-gray-900">{formatDate(user!.lastLoginAt)}</dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Failed Login Attempts</dt>
                  <dd class="mt-1 text-sm text-gray-900">{user!.failedLoginAttempts}</dd>
                </div>
                {user?.lockedUntil && (
                  <div>
                    <dt class="text-sm font-medium text-gray-500">Locked Until</dt>
                    <dd class="mt-1 text-sm text-red-700 font-semibold">{formatDate(user.lockedUntil)}</dd>
                  </div>
                )}
              </dl>
            </div>
          )}

          <!-- Permission Changes Notice -->
          <div class="card bg-blue-50 border border-blue-200 rounded-lg shadow p-6 mt-4">
            <h3 class="text-sm font-semibold text-blue-900 mb-2">ℹ️ Permission Changes</h3>
            <p class="text-xs text-blue-800">
              Role and permission changes apply immediately to active user sessions.
            </p>
          </div>
        </div>
      </div>
    )}
  </div>
</MainLayout>

<style>
  .back-link {
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  .status-badge {
    font-weight: 500;
  }

  .card {
    transition: box-shadow 0.2s;
  }

  .card:hover {
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }

  .field-error {
    color: #dc2626;
    font-size: 0.875rem;
    margin-top: 0.25rem;
  }

  .field-error:not(.hidden) {
    display: block;
  }

  #form-success {
    color: #16a34a;
    font-size: 0.875rem;
    padding: 0.75rem;
    background-color: #f0fdf4;
    border: 1px solid #86efac;
    border-radius: 0.375rem;
  }

  #form-success:not(.hidden) {
    display: block;
  }

  #form-error {
    color: #dc2626;
    font-size: 0.875rem;
    padding: 0.75rem;
    background-color: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 0.375rem;
  }

  #form-error:not(.hidden) {
    display: block;
  }

  .role-info {
    padding-bottom: 1rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .role-info:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  @media (max-width: 768px) {
    .form-actions {
      flex-direction: column;
    }

    .form-actions button,
    .form-actions a {
      width: 100%;
      text-align: center;
    }
  }
</style>

<script>
  /**
   * Client-side functionality for user create/edit page
   * Handles form validation, submission, and role description updates
   */

  interface ValidationResult {
    valid: boolean;
    errors: Record<string, string>;
  }

  // DOM elements
  const userForm = document.getElementById('user-form') as HTMLFormElement;
  const saveBtn = document.getElementById('save-btn');
  const formError = document.getElementById('form-error');
  const formSuccess = document.getElementById('form-success');
  const roleSelect = document.getElementById('role') as HTMLSelectElement;
  const roleDescription = document.getElementById('role-description');

  const isCreateMode = userForm?.dataset.mode === 'create';

  // Role descriptions for dynamic display
  const roleDescriptions: Record<string, string> = {
    'Administrator': 'Full system access including user management',
    'Manager': 'Manage suppliers, inventory, and generate reports',
    'Analyst': 'Upload pricelists, approve matches, and generate reports',
    'Clerk': 'Upload pricelists and adjust inventory',
    'Sales_Associate': 'Process sales transactions'
  };

  // Update role description when role changes
  roleSelect?.addEventListener('change', () => {
    const selectedRole = roleSelect.value;
    if (roleDescription && selectedRole) {
      roleDescription.textContent = roleDescriptions[selectedRole] || '';
    } else if (roleDescription) {
      roleDescription.textContent = '';
    }
  });

  // Initialize role description on page load
  if (roleSelect && roleDescription && roleSelect.value) {
    roleDescription.textContent = roleDescriptions[roleSelect.value] || '';
  }

  // Form validation
  function validateForm(formData: FormData): ValidationResult {
    const errors: Record<string, string> = {};

    // Email validation
    const email = formData.get('email')?.toString().trim();
    if (!email) {
      errors.email = 'Email is required';
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errors.email = 'Invalid email format';
    }

    // Display name validation
    const displayName = formData.get('displayName')?.toString().trim();
    if (!displayName) {
      errors.displayName = 'Display name is required';
    }

    // Role validation
    const role = formData.get('role')?.toString();
    if (!role) {
      errors.role = 'Role is required';
    }

    // Password validation (create mode only)
    if (isCreateMode) {
      const password = formData.get('password')?.toString();
      const confirmPassword = formData.get('confirmPassword')?.toString();

      if (!password) {
        errors.password = 'Password is required';
      } else if (password.length < 6) {
        errors.password = 'Password must be at least 6 characters';
      }

      if (!confirmPassword) {
        errors.confirmPassword = 'Please confirm your password';
      } else if (password !== confirmPassword) {
        errors.confirmPassword = 'Passwords do not match';
      }
    }

    return {
      valid: Object.keys(errors).length === 0,
      errors
    };
  }

  // Display validation errors
  function displayErrors(errors: Record<string, string>) {
    clearErrors();

    Object.entries(errors).forEach(([field, message]) => {
      const errorDiv = document.getElementById(`${field}-error`);
      if (errorDiv) {
        errorDiv.textContent = message;
        errorDiv.classList.remove('hidden');
      }
    });
  }

  // Clear all validation errors and messages
  function clearErrors() {
    const errorDivs = document.querySelectorAll('.field-error');
    errorDivs.forEach(div => {
      div.textContent = '';
      div.classList.add('hidden');
    });
    
    if (formError) {
      formError.textContent = '';
      formError.classList.add('hidden');
    }

    if (formSuccess) {
      formSuccess.textContent = '';
      formSuccess.classList.add('hidden');
    }
  }

  // Handle form submission
  userForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErrors();

    const formData = new FormData(userForm);
    const validation = validateForm(formData);

    if (!validation.valid) {
      displayErrors(validation.errors);
      return;
    }

    // Disable save button during submission
    if (saveBtn) {
      saveBtn.setAttribute('disabled', 'true');
      saveBtn.textContent = isCreateMode ? 'Creating...' : 'Saving...';
    }

    try {
      if (isCreateMode) {
        // Create new user
        const createData = {
          email: formData.get('email')?.toString().trim(),
          displayName: formData.get('displayName')?.toString().trim(),
          role: formData.get('role')?.toString(),
          password: formData.get('password')?.toString(),
        };

        const response = await fetch('/api/users/create', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(createData),
        });

        if (!response.ok) {
          const errorData = await response.json();
          throw new Error(errorData.error || 'Failed to create user');
        }

        const result = await response.json();

        // Show success message
        if (formSuccess) {
          formSuccess.textContent = 'User created successfully! Redirecting...';
          formSuccess.classList.remove('hidden');
        }

        // Redirect to user list after short delay
        setTimeout(() => {
          window.location.href = '/admin/users';
        }, 1500);
      } else {
        // Update existing user
        const userId = userForm.dataset.userId;
        
        const updateData = {
          displayName: formData.get('displayName')?.toString().trim(),
          role: formData.get('role')?.toString(),
          isActive: formData.get('isActive') === 'on',
        };

        const response = await fetch(`/api/users/${userId}`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(updateData),
        });

        if (!response.ok) {
          const errorData = await response.json();
          throw new Error(errorData.error || 'Failed to update user');
        }

        // Show success message
        if (formSuccess) {
          formSuccess.textContent = 'User updated successfully! Redirecting...';
          formSuccess.classList.remove('hidden');
        }

        // Redirect to user list after short delay
        setTimeout(() => {
          window.location.href = '/admin/users';
        }, 1500);
      }
    } catch (error) {
      if (formError) {
        formError.textContent = error instanceof Error ? error.message : 'Operation failed';
        formError.classList.remove('hidden');
      }

      // Re-enable save button
      if (saveBtn) {
        saveBtn.removeAttribute('disabled');
        saveBtn.textContent = isCreateMode ? 'Create User' : 'Save Changes';
      }
    }
  });
</script>

</content>
