rules_version = '2';

/**
 * Firebase Storage Security Rules for PRO SYNAPSE
 * 
 * Enforces:
 * - Authenticated access for all file operations (Requirement 1.3)
 * - Role-based upload permissions
 * - File size limits to prevent abuse
 * - Data encryption in transit via TLS 1.3+ (Requirement 19.1)
 * - Data encryption at rest (Requirement 19.2 - handled by Firebase)
 */

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function: Get user data from Firestore
    function getUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function: Check if user has specific role
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    // Helper function: Check if user has any of the specified roles
    function hasAnyRole(roles) {
      return isAuthenticated() && getUserData().role in roles;
    }
    
    // Helper function: Check if user account is active
    function isActiveUser() {
      return isAuthenticated() && getUserData().isActive == true;
    }
    
    // Helper function: Validate file size (max 10MB for documents)
    // Requirement 19.1, 19.2 - enforces reasonable limits for document uploads
    function isValidFileSize() {
      return request.resource.size <= 10 * 1024 * 1024;
    }
    
    // Helper function: Validate document file types (CSV, Excel .xls/.xlsx, PDF only)
    // Requirement 19.1, 19.2 - validates only allowed file types
    function isValidDocumentType() {
      return request.resource.contentType.matches('application/pdf') ||
             request.resource.contentType.matches('text/csv') ||
             request.resource.contentType.matches('application/vnd.ms-excel') ||
             request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.spreadsheetml.sheet');
    }
    
    // Pricelists directory - for uploaded supplier pricelists
    match /pricelists/{supplierId}/{fileName} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['Administrator', 'Manager', 'Analyst']) &&
                      isValidFileSize() &&
                      isValidDocumentType();
      allow delete: if hasRole('Administrator');
    }
    
    // Invoices directory - for uploaded invoice documents
    match /invoices/{supplierId}/{fileName} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['Administrator', 'Manager', 'Clerk']) &&
                      isValidFileSize() &&
                      isValidDocumentType();
      allow delete: if hasRole('Administrator');
    }
    
    // Delivery receipts directory
    match /delivery_receipts/{supplierId}/{fileName} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['Administrator', 'Manager', 'Clerk']) &&
                      isValidFileSize() &&
                      isValidDocumentType();
      allow delete: if hasRole('Administrator');
    }
    
    // Reports directory - for generated reports
    match /reports/{userId}/{fileName} {
      allow read: if isActiveUser() && (request.auth.uid == userId || hasRole('Administrator'));
      allow write: if isActiveUser() && request.auth.uid == userId;
      allow delete: if isActiveUser() && request.auth.uid == userId;
    }
    
    // Default deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
