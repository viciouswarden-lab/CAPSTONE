---
/**
 * DataTable Component
 * 
 * Displays tabular data with sorting, pagination, and selection capabilities.
 * Used for displaying products, transactions, pricelists, and other data.
 * 
 * Props:
 * - columns: Array of column definitions { key: string, label: string, sortable?: boolean, align?: 'left' | 'center' | 'right' }
 * - data: Array of data objects to display
 * - keyField: Field to use as unique key for rows (default: 'id')
 * - striped: Enable zebra striping (default: true)
 * - hoverable: Enable row hover effect (default: true)
 * - bordered: Enable borders (default: true)
 * - emptyMessage: Message to show when no data (default: 'No data available')
 */

interface Column {
  key: string;
  label: string;
  sortable?: boolean;
  align?: 'left' | 'center' | 'right';
  format?: (value: any) => string;
}

interface Props {
  columns: Column[];
  data: any[];
  keyField?: string;
  striped?: boolean;
  hoverable?: boolean;
  bordered?: boolean;
  emptyMessage?: string;
}

const { 
  columns, 
  data, 
  keyField = 'id',
  striped = true,
  hoverable = true,
  bordered = true,
  emptyMessage = 'No data available'
} = Astro.props;

const alignClass = (align?: string) => {
  switch (align) {
    case 'center': return 'text-center';
    case 'right': return 'text-right';
    default: return 'text-left';
  }
};
---

<div class="data-table-container overflow-x-auto">
  <table class={`data-table w-full ${bordered ? 'border border-gray-300' : ''}`}>
    <thead class="bg-gray-100 border-b-2 border-gray-300">
      <tr>
        {columns.map(col => (
          <th 
            class={`px-4 py-3 font-semibold text-gray-700 ${alignClass(col.align)}`}
            data-sortable={col.sortable ? 'true' : 'false'}
            data-key={col.key}
          >
            <div class={`flex items-center gap-2 ${col.align === 'center' ? 'justify-center' : col.align === 'right' ? 'justify-end' : ''}`}>
              <span>{col.label}</span>
              {col.sortable && (
                <span class="sort-icon text-gray-400" aria-label="Sortable">⇅</span>
              )}
            </div>
          </th>
        ))}
      </tr>
    </thead>
    <tbody>
      {data.length === 0 ? (
        <tr>
          <td 
            colspan={columns.length} 
            class="px-4 py-8 text-center text-gray-500 italic"
          >
            {emptyMessage}
          </td>
        </tr>
      ) : (
        data.map((row, rowIndex) => (
          <tr 
            class={`
              ${striped && rowIndex % 2 === 1 ? 'bg-gray-50' : 'bg-white'}
              ${hoverable ? 'hover:bg-blue-50 transition-colors' : ''}
              ${bordered ? 'border-b border-gray-200' : ''}
            `}
            data-row-key={row[keyField]}
          >
            {columns.map(col => (
              <td class={`px-4 py-3 ${alignClass(col.align)}`}>
                {col.format ? col.format(row[col.key]) : row[col.key] ?? '-'}
              </td>
            ))}
          </tr>
        ))
      )}
    </tbody>
  </table>
</div>

<style>
  .data-table {
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .data-table thead th {
    position: sticky;
    top: 0;
    z-index: 10;
    white-space: nowrap;
  }

  .data-table tbody tr {
    transition: background-color 0.15s ease;
  }

  .data-table th[data-sortable="true"] {
    cursor: pointer;
    user-select: none;
  }

  .data-table th[data-sortable="true"]:hover {
    background-color: #e5e7eb;
  }

  .sort-icon {
    font-size: 0.75rem;
    transition: color 0.2s;
  }

  .data-table th[data-sortable="true"]:hover .sort-icon {
    color: #3b82f6;
  }

  .data-table-container {
    max-height: 600px;
    border-radius: 0.375rem;
  }

  @media (max-width: 768px) {
    .data-table {
      font-size: 0.75rem;
    }

    .data-table td,
    .data-table th {
      padding: 0.5rem;
    }
  }
</style>

<script>
  // Client-side sorting functionality
  document.addEventListener('DOMContentLoaded', () => {
    const tables = document.querySelectorAll<HTMLTableElement>('.data-table');
    
    tables.forEach(table => {
      const headers = table.querySelectorAll<HTMLTableCellElement>('th[data-sortable="true"]');
      
      headers.forEach(header => {
        header.addEventListener('click', () => {
          const key = header.dataset.key;
          const tbody = table.querySelector<HTMLTableSectionElement>('tbody');
          if (!tbody) return;
          
          const rows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>('tr'));
          
          // Determine sort direction
          const currentDir = header.dataset.sortDir || 'asc';
          const newDir = currentDir === 'asc' ? 'desc' : 'asc';
          
          // Clear all sort indicators
          headers.forEach(h => {
            h.dataset.sortDir = '';
            const icon = h.querySelector('.sort-icon');
            if (icon) icon.textContent = '⇅';
          });
          
          // Set new sort direction
          header.dataset.sortDir = newDir;
          const icon = header.querySelector('.sort-icon');
          if (icon) icon.textContent = newDir === 'asc' ? '↑' : '↓';
          
          // Sort rows
          const parent = header.parentElement;
          if (!parent) return;
          
          const colIndex = Array.from(parent.children).indexOf(header);
          rows.sort((a, b) => {
            const aVal = a.children[colIndex]?.textContent?.trim() || '';
            const bVal = b.children[colIndex]?.textContent?.trim() || '';
            
            // Try numeric comparison first
            const aNum = parseFloat(aVal.replace(/[^0-9.-]/g, ''));
            const bNum = parseFloat(bVal.replace(/[^0-9.-]/g, ''));
            
            if (!isNaN(aNum) && !isNaN(bNum)) {
              return newDir === 'asc' ? aNum - bNum : bNum - aNum;
            }
            
            // Fallback to string comparison
            return newDir === 'asc' 
              ? aVal.localeCompare(bVal)
              : bVal.localeCompare(aVal);
          });
          
          // Re-append sorted rows
          rows.forEach(row => tbody.appendChild(row));
        });
      });
    });
  });
</script>
