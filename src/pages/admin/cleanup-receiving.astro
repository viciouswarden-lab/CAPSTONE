---
/**
 * Cleanup Receiving Records - Admin Utility
 * 
 * Deletes receiving records and resets inventory quantities
 */

import ModernLayout from '../../layouts/ModernLayout.astro';

Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');
---

<ModernLayout title="Cleanup Receiving Records">
  <div class="cleanup-page">
    <div class="page-header">
      <div>
        <h1>
          <span class="material-symbols-outlined" style="vertical-align: middle; margin-right: 0.5rem;">delete_sweep</span>
          Cleanup Receiving Records
        </h1>
        <p class="subtitle">Delete test receiving records and reset inventory</p>
      </div>
      <a href="/admin" class="btn btn-secondary">
        <span class="material-symbols-outlined">arrow_back</span>
        Back to Admin
      </a>
    </div>

    <div class="card">
      <div class="card-header">
        <h2>Cleanup Options</h2>
      </div>
      <div class="card-body">
        <div class="alert alert-warning">
          <span class="material-symbols-outlined">warning</span>
          <div>
            <strong>Warning:</strong> These actions cannot be undone. Use with caution.
          </div>
        </div>

        <div class="cleanup-options">
          <div class="cleanup-option">
            <h3>Delete All Receiving Records</h3>
            <p>Removes all receiving records from the database. Does not affect inventory.</p>
            <button id="delete-receiving-btn" class="btn btn-danger">
              <span class="material-symbols-outlined">delete</span>
              Delete All Receiving Records
            </button>
          </div>

          <div class="cleanup-option">
            <h3>Reset All Inventory to Zero</h3>
            <p>Sets all product inventory quantities to 0. Does not delete inventory records.</p>
            <button id="reset-inventory-btn" class="btn btn-danger">
              <span class="material-symbols-outlined">restart_alt</span>
              Reset All Inventory
            </button>
          </div>

          <div class="cleanup-option">
            <h3>Full Cleanup (Recommended)</h3>
            <p>Deletes all receiving records AND resets inventory to zero. Clean slate for testing.</p>
            <button id="full-cleanup-btn" class="btn btn-danger">
              <span class="material-symbols-outlined">delete_forever</span>
              Full Cleanup
            </button>
          </div>
        </div>

        <div id="result-display" class="hidden">
          <div id="result-alert" class="alert">
            <span class="material-symbols-outlined" id="result-icon">check_circle</span>
            <div>
              <strong id="result-title"></strong>
              <p id="result-message"></p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Progress Modal -->
    <div id="progress-modal" class="modal hidden">
      <div class="modal-overlay"></div>
      <div class="modal-content modal-sm">
        <div class="modal-body text-center">
          <div class="spinner" style="margin: 0 auto 1rem;"></div>
          <h3 id="progress-title">Processing...</h3>
          <p id="progress-message" class="progress-message">Please wait...</p>
        </div>
      </div>
    </div>
  </div>
</ModernLayout>

<script>
  import { db } from '../../services/firebase';
  import { collection, getDocs, deleteDoc, doc, writeBatch, updateDoc } from 'firebase/firestore';

  const deleteReceivingBtn = document.getElementById('delete-receiving-btn') as HTMLButtonElement;
  const resetInventoryBtn = document.getElementById('reset-inventory-btn') as HTMLButtonElement;
  const fullCleanupBtn = document.getElementById('full-cleanup-btn') as HTMLButtonElement;
  const resultDisplay = document.getElementById('result-display')!;
  const resultAlert = document.getElementById('result-alert')!;
  const resultIcon = document.getElementById('result-icon')!;
  const resultTitle = document.getElementById('result-title')!;
  const resultMessage = document.getElementById('result-message')!;
  const progressModal = document.getElementById('progress-modal')!;
  const progressTitle = document.getElementById('progress-title')!;
  const progressMessage = document.getElementById('progress-message')!;

  const showProgress = (title: string, message: string) => {
    progressTitle.textContent = title;
    progressMessage.textContent = message;
    progressModal.classList.remove('hidden');
  };

  const hideProgress = () => {
    progressModal.classList.add('hidden');
  };

  const showResult = (success: boolean, title: string, message: string) => {
    resultAlert.className = success ? 'alert alert-success' : 'alert alert-error';
    resultIcon.textContent = success ? 'check_circle' : 'error';
    resultTitle.textContent = title;
    resultMessage.textContent = message;
    resultDisplay.classList.remove('hidden');
  };

  const deleteAllReceiving = async () => {
    if (!confirm('Are you sure you want to delete ALL receiving records? This cannot be undone.')) {
      return;
    }

    showProgress('Deleting Receiving Records', 'Please wait...');

    try {
      const receivingRef = collection(db!, 'receiving_records');
      const snapshot = await getDocs(receivingRef);

      let deletedCount = 0;
      const deletePromises = snapshot.docs.map(async (docSnapshot) => {
        await deleteDoc(doc(db!, 'receiving_records', docSnapshot.id));
        deletedCount++;
      });

      await Promise.all(deletePromises);

      hideProgress();
      showResult(true, 'Success!', `Deleted ${deletedCount} receiving record(s).`);
    } catch (error) {
      hideProgress();
      showResult(false, 'Error', error instanceof Error ? error.message : 'Failed to delete records');
      console.error('Delete error:', error);
    }
  };

  const resetAllInventory = async () => {
    if (!confirm('Are you sure you want to reset ALL inventory to zero? This cannot be undone.')) {
      return;
    }

    showProgress('Resetting Inventory', 'Please wait...');

    try {
      const inventoryRef = collection(db!, 'inventory');
      const snapshot = await getDocs(inventoryRef);

      const batch = writeBatch(db!);
      let resetCount = 0;

      snapshot.docs.forEach((docSnapshot) => {
        const docRef = doc(db!, 'inventory', docSnapshot.id);
        batch.update(docRef, { quantityOnHand: 0 });
        resetCount++;
      });

      await batch.commit();

      hideProgress();
      showResult(true, 'Success!', `Reset ${resetCount} inventory record(s) to zero.`);
    } catch (error) {
      hideProgress();
      showResult(false, 'Error', error instanceof Error ? error.message : 'Failed to reset inventory');
      console.error('Reset error:', error);
    }
  };

  const fullCleanup = async () => {
    if (!confirm('Are you sure you want to DELETE ALL receiving records AND reset inventory to zero?\n\nThis is a complete cleanup and cannot be undone!')) {
      return;
    }

    showProgress('Full Cleanup', 'Deleting receiving records...');

    try {
      // Step 1: Delete receiving records
      const receivingRef = collection(db!, 'receiving_records');
      const receivingSnapshot = await getDocs(receivingRef);

      let deletedCount = 0;
      const deletePromises = receivingSnapshot.docs.map(async (docSnapshot) => {
        await deleteDoc(doc(db!, 'receiving_records', docSnapshot.id));
        deletedCount++;
      });

      await Promise.all(deletePromises);

      progressMessage.textContent = 'Resetting inventory...';

      // Step 2: Reset inventory
      const inventoryRef = collection(db!, 'inventory');
      const inventorySnapshot = await getDocs(inventoryRef);

      const batch = writeBatch(db!);
      let resetCount = 0;

      inventorySnapshot.docs.forEach((docSnapshot) => {
        const docRef = doc(db!, 'inventory', docSnapshot.id);
        batch.update(docRef, { quantityOnHand: 0 });
        resetCount++;
      });

      await batch.commit();

      hideProgress();
      showResult(
        true,
        'Full Cleanup Complete!',
        `Deleted ${deletedCount} receiving record(s) and reset ${resetCount} inventory record(s) to zero.`
      );
    } catch (error) {
      hideProgress();
      showResult(false, 'Error', error instanceof Error ? error.message : 'Cleanup failed');
      console.error('Cleanup error:', error);
    }
  };

  deleteReceivingBtn.addEventListener('click', deleteAllReceiving);
  resetInventoryBtn.addEventListener('click', resetAllInventory);
  fullCleanupBtn.addEventListener('click', fullCleanup);
</script>

<style>
  .cleanup-page {
    padding: 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
    gap: 2rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
    color: var(--text-primary);
    display: flex;
    align-items: center;
  }

  .subtitle {
    color: var(--text-secondary);
    margin: 0;
  }

  .card {
    background: white;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    overflow: hidden;
  }

  .card-header {
    padding: 1.5rem;
    background: var(--surface-secondary);
    border-bottom: 1px solid var(--border-color);
  }

  .card-header h2 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
  }

  .card-body {
    padding: 1.5rem;
  }

  .alert {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    border: 1px solid;
  }

  .alert-warning {
    background: #fffbeb;
    color: #92400e;
    border-color: #fcd34d;
  }

  .alert-success {
    background: #d1fae5;
    color: #065f46;
    border-color: #6ee7b7;
  }

  .alert-error {
    background: #fef2f2;
    color: #991b1b;
    border-color: #fca5a5;
  }

  .alert .material-symbols-outlined {
    font-size: 24px;
  }

  .cleanup-options {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .cleanup-option {
    padding: 1.5rem;
    border: 2px solid var(--border-color);
    border-radius: 8px;
  }

  .cleanup-option h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.125rem;
  }

  .cleanup-option p {
    margin: 0 0 1rem 0;
    color: var(--text-secondary);
  }

  .hidden {
    display: none !important;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    font-weight: 500;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-secondary {
    background: white;
    color: var(--text-primary);
    border: 1px solid var(--border-color);
  }

  .btn-secondary:hover {
    background: var(--surface-secondary);
  }

  .btn-danger {
    background: #dc2626;
    color: white;
  }

  .btn-danger:hover {
    background: #991b1b;
  }

  .modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }

  .modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
  }

  .modal-content {
    position: relative;
    background: white;
    border-radius: 8px;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    max-width: 400px;
    width: 90%;
    z-index: 1001;
  }

  .modal-sm {
    max-width: 400px;
  }

  .modal-body {
    padding: 2rem;
  }

  .modal-body h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.25rem;
  }

  .spinner {
    width: 48px;
    height: 48px;
    border: 4px solid var(--border-color);
    border-top-color: var(--primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .progress-message {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .text-center {
    text-align: center;
  }

  @media (max-width: 768px) {
    .cleanup-page {
      padding: 1rem;
    }

    .page-header {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
