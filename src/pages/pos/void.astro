---
/**
 * POS Transaction Void Page
 * 
 * Allows managers to void completed transactions with confirmation.
 * Displays recent transactions and reverses inventory upon void.
 * 
 * Requirements: 13.5
 * Task: 32.2
 */

import ModernLayout from '../../layouts/ModernLayout.astro';
import ErrorMessage from '../../components/ErrorMessage.astro';
import LoadingSpinner from '../../components/LoadingSpinner.astro';
---

<ModernLayout title="Void Transaction" requireAuth={true} requiredRole="Manager">
  <!-- Page Header -->
  <div class="page-header">
    <h1 class="text-2xl font-bold text-gray-900">Void Transaction</h1>
    <p class="text-sm text-gray-600 mt-1">Review and void completed transactions. Manager role required.</p>
  </div>

  <!-- Filters Section -->
  <div class="card filters-section">
    <h2 class="section-title">Filter Transactions</h2>
    
    <div class="filter-form">
      <div class="form-group">
        <label for="start-date">Start Date</label>
        <input
          type="date"
          id="start-date"
          class="form-input"
        />
      </div>
      
      <div class="form-group">
        <label for="end-date">End Date</label>
        <input
          type="date"
          id="end-date"
          class="form-input"
        />
      </div>
      
      <div class="form-group">
        <label for="status-filter">Status</label>
        <select id="status-filter" class="form-select">
          <option value="all">All</option>
          <option value="completed" selected>Completed</option>
          <option value="voided">Voided</option>
        </select>
      </div>
      
      <div class="form-group">
        <button type="button" id="apply-filters-btn" class="btn-primary">
          Apply Filters
        </button>
      </div>
    </div>
  </div>

  <!-- Transactions List -->
  <div class="card transactions-section">
    <h2 class="section-title">Recent Transactions</h2>
    
    <!-- Loading State -->
    <div id="loading-state" class="loading-state hidden">
      <LoadingSpinner />
      <p>Loading transactions...</p>
    </div>
    
    <!-- Error State -->
    <div id="error-state" class="error-state hidden"></div>
    
    <!-- Empty State -->
    <div id="empty-state" class="empty-state hidden">
      <p>No transactions found for the selected filters.</p>
    </div>
    
    <!-- Transactions Table -->
    <div id="transactions-table" class="transactions-table hidden">
      <table class="data-table">
        <thead>
          <tr>
            <th>Transaction ID</th>
            <th>Date & Time</th>
            <th>Items</th>
            <th>Total</th>
            <th>Payment Method</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="transactions-body">
          <!-- Transactions will be inserted here -->
        </tbody>
      </table>
    </div>
  </div>

  <!-- Void Confirmation Modal -->
  <div id="void-modal" class="modal hidden">
    <div class="modal-content">
      <div class="modal-header warning">
        <h3>⚠️ Confirm Transaction Void</h3>
      </div>
      <div class="modal-body">
        <p class="warning-text">
          <strong>Warning:</strong> This action will void the transaction and reverse all inventory adjustments.
          This action cannot be undone.
        </p>
        
        <div class="transaction-details">
          <h4>Transaction Details</h4>
          <div class="detail-row">
            <span class="detail-label">Transaction ID:</span>
            <span class="detail-value" id="modal-transaction-id"></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Date & Time:</span>
            <span class="detail-value" id="modal-timestamp"></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Total Amount:</span>
            <span class="detail-value" id="modal-total"></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Payment Method:</span>
            <span class="detail-value" id="modal-payment-method"></span>
          </div>
        </div>
        
        <div class="line-items">
          <h4>Line Items</h4>
          <table class="line-items-table">
            <thead>
              <tr>
                <th>Description</th>
                <th>Qty</th>
                <th>Unit Price</th>
                <th>Line Total</th>
              </tr>
            </thead>
            <tbody id="modal-line-items">
              <!-- Line items will be inserted here -->
            </tbody>
          </table>
        </div>
        
        <div class="form-group">
          <label for="void-reason">Reason for Void (Required)</label>
          <textarea
            id="void-reason"
            class="form-textarea"
            rows="3"
            placeholder="Please provide a reason for voiding this transaction..."
            required
          ></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" id="cancel-void-btn" class="btn-secondary">
          Cancel
        </button>
        <button type="button" id="confirm-void-btn" class="btn-danger">
          Confirm Void
        </button>
      </div>
    </div>
  </div>

  <!-- Success Modal -->
  <div id="success-modal" class="modal hidden">
    <div class="modal-content">
      <div class="modal-header success">
        <h3>✓ Transaction Voided Successfully</h3>
      </div>
      <div class="modal-body">
        <p>The transaction has been voided and inventory has been restored.</p>
        <p><strong>Transaction ID:</strong> <span id="success-transaction-id"></span></p>
      </div>
      <div class="modal-footer">
        <button type="button" id="success-close-btn" class="btn-primary">
          Close
        </button>
      </div>
    </div>
  </div>

  <!-- Styles -->
  <style>
    .page-header {
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 2px solid var(--color-border);
    }

    .card {
      background: white;
      border-radius: var(--radius-lg);
      padding: 1.5rem;
      box-shadow: var(--shadow-md);
      margin-bottom: 1.5rem;
    }

    .section-title {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 1rem;
      color: var(--color-text);
    }

    /* Filters */
    .filter-form {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      align-items: end;
    }

    .form-group {
      display: flex;
      flex-direction: column;
    }

    .form-group label {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--color-text-secondary);
      margin-bottom: 0.25rem;
    }

    .form-input, .form-select, .form-textarea {
      padding: 0.5rem;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      font-size: 0.875rem;
    }

    .form-input:focus, .form-select:focus, .form-textarea:focus {
      outline: none;
      border-color: var(--color-primary);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    .form-textarea {
      resize: vertical;
      font-family: inherit;
    }

    /* Buttons */
    .btn-primary, .btn-secondary, .btn-danger {
      padding: 0.625rem 1.25rem;
      font-size: 0.875rem;
      font-weight: 600;
      border: none;
      border-radius: var(--radius-md);
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-primary {
      background-color: var(--color-primary);
      color: white;
    }

    .btn-primary:hover:not(:disabled) {
      background-color: var(--color-primary-dark);
      transform: translateY(-1px);
      box-shadow: var(--shadow-md);
    }

    .btn-secondary {
      background-color: #6b7280;
      color: white;
    }

    .btn-secondary:hover:not(:disabled) {
      background-color: #4b5563;
    }

    .btn-danger {
      background-color: var(--color-danger);
      color: white;
    }

    .btn-danger:hover:not(:disabled) {
      background-color: #dc2626;
      transform: translateY(-1px);
    }

    .btn-void {
      padding: 0.375rem 0.875rem;
      font-size: 0.75rem;
      background-color: var(--color-danger);
      color: white;
      border: none;
      border-radius: var(--radius-sm);
      cursor: pointer;
      font-weight: 600;
    }

    .btn-void:hover:not(:disabled) {
      background-color: #dc2626;
    }

    .btn-void:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* States */
    .loading-state, .error-state, .empty-state {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--color-text-secondary);
    }

    .error-state {
      color: var(--color-danger);
    }

    /* Table */
    .data-table {
      width: 100%;
      border-collapse: collapse;
    }

    .data-table thead {
      background-color: var(--color-surface);
    }

    .data-table th {
      padding: 0.75rem 0.5rem;
      text-align: left;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--color-text-secondary);
      text-transform: uppercase;
      border-bottom: 2px solid var(--color-border);
    }

    .data-table th:nth-child(4),
    .data-table th:nth-child(6),
    .data-table th:nth-child(7) {
      text-align: center;
    }

    .data-table td {
      padding: 0.75rem 0.5rem;
      border-bottom: 1px solid var(--color-border);
      font-size: 0.875rem;
    }

    .data-table td:nth-child(4),
    .data-table td:nth-child(6),
    .data-table td:nth-child(7) {
      text-align: center;
    }

    .data-table tr.voided {
      opacity: 0.6;
      text-decoration: line-through;
      background-color: #f9fafb;
    }

    .status-badge {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .status-badge.completed {
      background-color: #d1fae5;
      color: #065f46;
    }

    .status-badge.voided {
      background-color: #fee2e2;
      color: #991b1b;
    }

    .transaction-id {
      font-family: monospace;
      font-size: 0.75rem;
      color: var(--color-text-secondary);
    }

    /* Modal */
    .modal {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: rgba(0, 0, 0, 0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 9999;
    }

    .modal-content {
      background: white;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
      max-width: 600px;
      width: 90%;
      max-height: 90vh;
      overflow-y: auto;
    }

    .modal-header {
      padding: 1.5rem;
      border-bottom: 1px solid var(--color-border);
    }

    .modal-header.warning {
      background-color: #fef3c7;
      color: #92400e;
    }

    .modal-header.success {
      background-color: #d1fae5;
      color: #065f46;
    }

    .modal-header h3 {
      margin: 0;
      font-size: 1.25rem;
      font-weight: 700;
    }

    .modal-body {
      padding: 1.5rem;
    }

    .warning-text {
      padding: 1rem;
      background-color: #fef3c7;
      border: 1px solid #f59e0b;
      border-radius: var(--radius-md);
      color: #92400e;
      margin-bottom: 1.5rem;
    }

    .transaction-details {
      margin-bottom: 1.5rem;
    }

    .transaction-details h4 {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--color-text-secondary);
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }

    .detail-row {
      display: flex;
      justify-content: space-between;
      padding: 0.5rem 0;
      border-bottom: 1px solid var(--color-border);
    }

    .detail-label {
      color: var(--color-text-secondary);
      font-size: 0.875rem;
    }

    .detail-value {
      font-weight: 600;
      color: var(--color-text);
      font-size: 0.875rem;
    }

    .line-items {
      margin-bottom: 1.5rem;
    }

    .line-items h4 {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--color-text-secondary);
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }

    .line-items-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.875rem;
    }

    .line-items-table th {
      padding: 0.5rem;
      text-align: left;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--color-text-secondary);
      background-color: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
    }

    .line-items-table th:nth-child(2),
    .line-items-table th:nth-child(3),
    .line-items-table th:nth-child(4) {
      text-align: right;
    }

    .line-items-table td {
      padding: 0.5rem;
      border-bottom: 1px solid var(--color-border);
    }

    .line-items-table td:nth-child(2),
    .line-items-table td:nth-child(3),
    .line-items-table td:nth-child(4) {
      text-align: right;
    }

    .modal-footer {
      padding: 1rem 1.5rem;
      border-top: 1px solid var(--color-border);
      display: flex;
      justify-content: flex-end;
      gap: 0.75rem;
    }

    /* Hidden utility */
    .hidden {
      display: none !important;
    }

    /* Responsive Design */
    @media (max-width: 768px) {
      .filter-form {
        grid-template-columns: 1fr;
      }

      .data-table {
        font-size: 0.75rem;
      }

      .data-table th,
      .data-table td {
        padding: 0.5rem 0.25rem;
      }
    }
  </style>

  <!-- JavaScript for void functionality -->
  <script>
    import { posService } from '../../services/pos/POSService';
    import type { POSTransaction } from '../../types/models';

    // ========================================================================
    // State Management
    // ========================================================================

    let transactions: POSTransaction[] = [];
    let selectedTransaction: POSTransaction | null = null;

    // ========================================================================
    // DOM Elements
    // ========================================================================

    const startDateInput = document.getElementById('start-date') as HTMLInputElement;
    const endDateInput = document.getElementById('end-date') as HTMLInputElement;
    const statusFilter = document.getElementById('status-filter') as HTMLSelectElement;
    const applyFiltersBtn = document.getElementById('apply-filters-btn') as HTMLButtonElement;

    const loadingState = document.getElementById('loading-state') as HTMLDivElement;
    const errorState = document.getElementById('error-state') as HTMLDivElement;
    const emptyState = document.getElementById('empty-state') as HTMLDivElement;
    const transactionsTable = document.getElementById('transactions-table') as HTMLDivElement;
    const transactionsBody = document.getElementById('transactions-body') as HTMLTableSectionElement;

    const voidModal = document.getElementById('void-modal') as HTMLDivElement;
    const cancelVoidBtn = document.getElementById('cancel-void-btn') as HTMLButtonElement;
    const confirmVoidBtn = document.getElementById('confirm-void-btn') as HTMLButtonElement;
    const voidReasonInput = document.getElementById('void-reason') as HTMLTextAreaElement;

    const modalTransactionIdEl = document.getElementById('modal-transaction-id') as HTMLSpanElement;
    const modalTimestampEl = document.getElementById('modal-timestamp') as HTMLSpanElement;
    const modalTotalEl = document.getElementById('modal-total') as HTMLSpanElement;
    const modalPaymentMethodEl = document.getElementById('modal-payment-method') as HTMLSpanElement;
    const modalLineItems = document.getElementById('modal-line-items') as HTMLTableSectionElement;

    const successModal = document.getElementById('success-modal') as HTMLDivElement;
    const successTransactionIdEl = document.getElementById('success-transaction-id') as HTMLSpanElement;
    const successCloseBtn = document.getElementById('success-close-btn') as HTMLButtonElement;

    // ========================================================================
    // Initialization
    // ========================================================================

    /**
     * Initialize the page
     */
    async function init() {
      // Set default date range (last 7 days)
      const endDate = new Date();
      const startDate = new Date();
      startDate.setDate(startDate.getDate() - 7);

      startDateInput.value = startDate.toISOString().split('T')[0];
      endDateInput.value = endDate.toISOString().split('T')[0];

      // Load transactions
      await loadTransactions();

      // Set up event listeners
      applyFiltersBtn.addEventListener('click', loadTransactions);
      cancelVoidBtn.addEventListener('click', closeVoidModal);
      confirmVoidBtn.addEventListener('click', handleVoidConfirm);
      successCloseBtn.addEventListener('click', closeSuccessModal);
    }

    // ========================================================================
    // Transaction Loading
    // ========================================================================

    /**
     * Load transactions based on filters
     */
    async function loadTransactions() {
      try {
        showLoading();

        const startDate = new Date(startDateInput.value);
        startDate.setHours(0, 0, 0, 0);

        const endDate = new Date(endDateInput.value);
        endDate.setHours(23, 59, 59, 999);

        // Load transactions from service
        transactions = await posService.getTransactionHistory({
          start: startDate,
          end: endDate
        });

        // Apply status filter
        const statusValue = statusFilter.value;
        if (statusValue !== 'all') {
          transactions = transactions.filter(t => t.status === statusValue);
        }

        // Sort by timestamp descending (newest first)
        transactions.sort((a, b) => b.timestamp.getTime() - a.timestamp.getTime());

        renderTransactions();

      } catch (error) {
        showError(error instanceof Error ? error.message : 'Failed to load transactions');
      }
    }

    /**
     * Render transactions table
     */
    function renderTransactions() {
      hideAllStates();

      if (transactions.length === 0) {
        emptyState.classList.remove('hidden');
        return;
      }

      transactionsTable.classList.remove('hidden');
      transactionsBody.innerHTML = '';

      transactions.forEach(transaction => {
        const row = document.createElement('tr');
        
        // Apply voided styling
        if (transaction.status === 'voided') {
          row.classList.add('voided');
        }

        const itemCount = transaction.lineItems.length;
        const itemLabel = itemCount === 1 ? 'item' : 'items';

        row.innerHTML = `
          <td>
            <span class="transaction-id">${transaction.transactionId}</span>
          </td>
          <td>${formatDateTime(transaction.timestamp)}</td>
          <td>${itemCount} ${itemLabel}</td>
          <td>${formatCurrency(transaction.total)}</td>
          <td>${formatPaymentMethod(transaction.paymentMethod)}</td>
          <td>
            <span class="status-badge ${transaction.status}">
              ${transaction.status}
            </span>
          </td>
          <td>
            ${transaction.status === 'completed' 
              ? `<button class="btn-void" data-transaction-id="${transaction.transactionId}">Void</button>`
              : '-'
            }
          </td>
        `;

        // Add void button event listener
        if (transaction.status === 'completed') {
          const voidBtn = row.querySelector('.btn-void') as HTMLButtonElement;
          voidBtn.addEventListener('click', () => showVoidModal(transaction));
        }

        transactionsBody.appendChild(row);
      });
    }

    // ========================================================================
    // Void Modal
    // ========================================================================

    /**
     * Show void confirmation modal
     */
    function showVoidModal(transaction: POSTransaction) {
      selectedTransaction = transaction;

      // Populate modal details
      modalTransactionIdEl.textContent = transaction.transactionId;
      modalTimestampEl.textContent = formatDateTime(transaction.timestamp);
      modalTotalEl.textContent = formatCurrency(transaction.total);
      modalPaymentMethodEl.textContent = formatPaymentMethod(transaction.paymentMethod);

      // Populate line items
      modalLineItems.innerHTML = '';
      transaction.lineItems.forEach(item => {
        const row = document.createElement('tr');
        row.innerHTML = `
          <td>${item.description}</td>
          <td>${item.quantity}</td>
          <td>${formatCurrency(item.unitPrice)}</td>
          <td>${formatCurrency(item.lineTotal)}</td>
        `;
        modalLineItems.appendChild(row);
      });

      // Clear reason
      voidReasonInput.value = '';

      // Show modal
      voidModal.classList.remove('hidden');
    }

    /**
     * Close void modal
     */
    function closeVoidModal() {
      voidModal.classList.add('hidden');
      selectedTransaction = null;
      voidReasonInput.value = '';
    }

    /**
     * Handle void confirmation
     */
    async function handleVoidConfirm() {
      if (!selectedTransaction) return;

      const reason = voidReasonInput.value.trim();
      if (!reason) {
        alert('Please provide a reason for voiding this transaction.');
        return;
      }

      try {
        confirmVoidBtn.disabled = true;
        confirmVoidBtn.textContent = 'Processing...';

        // Get current user ID from session
        const userId = getCurrentUserId();

        // Call POSService.voidTransaction - Requirement 13.5
        await posService.voidTransaction(selectedTransaction.transactionId, userId);

        // Close void modal
        closeVoidModal();

        // Show success modal
        showSuccessModal(selectedTransaction.transactionId);

        // Reload transactions
        await loadTransactions();

      } catch (error) {
        alert(error instanceof Error ? error.message : 'Failed to void transaction');
      } finally {
        confirmVoidBtn.disabled = false;
        confirmVoidBtn.textContent = 'Confirm Void';
      }
    }

    // ========================================================================
    // Success Modal
    // ========================================================================

    /**
     * Show success modal
     */
    function showSuccessModal(transactionId: string) {
      successTransactionIdEl.textContent = transactionId;
      successModal.classList.remove('hidden');
    }

    /**
     * Close success modal
     */
    function closeSuccessModal() {
      successModal.classList.add('hidden');
    }

    // ========================================================================
    // UI State Management
    // ========================================================================

    function showLoading() {
      hideAllStates();
      loadingState.classList.remove('hidden');
    }

    function showError(message: string) {
      hideAllStates();
      errorState.textContent = message;
      errorState.classList.remove('hidden');
    }

    function hideAllStates() {
      loadingState.classList.add('hidden');
      errorState.classList.add('hidden');
      emptyState.classList.add('hidden');
      transactionsTable.classList.add('hidden');
    }

    // ========================================================================
    // Helper Functions
    // ========================================================================

    function formatCurrency(amount: number): string {
      return `$${amount.toFixed(2)}`;
    }

    function formatDateTime(date: Date): string {
      const options: Intl.DateTimeFormatOptions = {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
      };
      return date.toLocaleDateString('en-US', options);
    }

    function formatPaymentMethod(method: string): string {
      return method.charAt(0).toUpperCase() + method.slice(1);
    }

    function getCurrentUserId(): string {
      // Get user ID from session storage or cookie
      // This should match the authentication system
      const userSession = sessionStorage.getItem('userSession');
      if (userSession) {
        const session = JSON.parse(userSession);
        return session.userId;
      }
      return 'unknown';
    }

    // ========================================================================
    // Page Load
    // ========================================================================

    // Initialize on page load
    init();
  </script>
</ModernLayout>
