---
/**
 * Point of Sale (POS) Page - Client-Side Functional
 * 
 * Features:
 * - Real product lookup from Firestore
 * - Shopping cart management
 * - Simulated payment processing (no real transactions)
 * - Updates inventory on "payment"
 * - Creates transaction records
 * - Shows in audit logs
 */

import ModernLayout from '../../layouts/ModernLayout.astro';

Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');
---

<ModernLayout title="Point of Sale">
  <div class="pos-page">
    <!-- Page Header -->
    <div class="page-header">
      <div>
        <h1>
          <span class="material-symbols-outlined">point_of_sale</span>
          Point of Sale
        </h1>
        <p class="subtitle">Fast checkout and inventory management</p>
      </div>
      <div class="page-actions">
        <button class="btn btn-secondary" id="view-transactions-btn">
          <span class="material-symbols-outlined">receipt_long</span>
          Transactions
        </button>
        <button class="btn btn-secondary" id="clear-all-btn">
          <span class="material-symbols-outlined">refresh</span>
          New Sale
        </button>
      </div>
    </div>

    <!-- Stats Row -->
    <div class="stats-grid" id="stats-grid">
      <div class="stat-card">
        <span class="material-symbols-outlined stat-icon" style="color: #10b981;">payments</span>
        <div class="stat-label">Today's Sales</div>
        <div class="stat-value" id="today-sales">₱0.00</div>
      </div>
      <div class="stat-card">
        <span class="material-symbols-outlined stat-icon" style="color: #3b82f6;">receipt</span>
        <div class="stat-label">Transactions</div>
        <div class="stat-value" id="today-transactions">0</div>
      </div>
      <div class="stat-card">
        <span class="material-symbols-outlined stat-icon" style="color: #f59e0b;">shopping_cart</span>
        <div class="stat-label">Cart Items</div>
        <div class="stat-value" id="cart-items">0</div>
      </div>
      <div class="stat-card">
        <span class="material-symbols-outlined stat-icon" style="color: #8b5cf6;">trending_up</span>
        <div class="stat-label">Cart Total</div>
        <div class="stat-value" id="cart-total">₱0.00</div>
      </div>
    </div>

    <!-- Main POS Interface -->
    <div class="pos-grid">
      <!-- Left: Product Lookup & Cart -->
      <div class="pos-left">
        <!-- Product Search -->
        <div class="card">
          <div class="card-header">
            <h2>Product Lookup</h2>
          </div>
          <div class="card-body">
            <div class="search-bar">
              <div class="search-input-wrapper">
                <span class="material-symbols-outlined search-icon">search</span>
                <input type="text" id="sku-input" class="search-input" 
                       placeholder="Search by SKU or product name..." 
                       autocomplete="off" autofocus />
                <div id="search-dropdown" class="search-dropdown hidden"></div>
              </div>
            </div>

            <!-- Product Display -->
            <div id="product-display" class="product-display hidden">
              <div class="product-info">
                <div class="product-name" id="product-name"></div>
                <div class="product-sku" id="product-sku"></div>
                <div class="product-price" id="product-price"></div>
                <div class="product-stock" id="product-stock"></div>
              </div>
              <div class="add-to-cart-section">
                <input type="number" id="quantity-input" class="quantity-input" 
                       value="1" min="1" />
                <button class="btn btn-success" id="add-to-cart-btn">
                  <span class="material-symbols-outlined">add_shopping_cart</span>
                  Add to Cart
                </button>
              </div>
            </div>

            <div id="product-empty" class="product-empty">
              <span class="material-symbols-outlined">barcode_scanner</span>
              <p>Search for a product by SKU or name</p>
            </div>
          </div>
        </div>

        <!-- Cart Items -->
        <div class="card">
          <div class="card-header">
            <h2>Cart Items</h2>
            <button class="btn btn-ghost" id="clear-cart-btn">Clear</button>
          </div>
          <div class="card-body">
            <div id="cart-items-container">
              <div class="cart-empty">
                <span class="material-symbols-outlined">shopping_cart</span>
                <p>No items in cart</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Summary & Payment -->
      <div class="pos-right">
        <!-- Order Summary -->
        <div class="card">
          <div class="card-header">
            <h2>Order Summary</h2>
          </div>
          <div class="card-body">
            <div class="summary-row">
              <span>Subtotal:</span>
              <span class="summary-value" id="subtotal">₱0.00</span>
            </div>
            <div class="summary-row">
              <span>Tax (0%):</span>
              <span class="summary-value" id="tax">₱0.00</span>
            </div>
            <div class="summary-row total-row">
              <span>Total:</span>
              <span class="summary-total" id="total">₱0.00</span>
            </div>
          </div>
        </div>

        <!-- Payment Method -->
        <div class="card">
          <div class="card-header">
            <h2>Payment Method</h2>
          </div>
          <div class="card-body">
            <div class="payment-methods">
              <button class="payment-btn active" data-method="cash">
                <span class="material-symbols-outlined">payments</span>
                Cash
              </button>
              <button class="payment-btn" data-method="card">
                <span class="material-symbols-outlined">credit_card</span>
                Card
              </button>
              <button class="payment-btn" data-method="gcash">
                <span class="material-symbols-outlined">phone_android</span>
                GCash
              </button>
            </div>
          </div>
        </div>

        <!-- Complete Transaction -->
        <button class="btn btn-primary btn-large" id="complete-transaction-btn" disabled>
          <span class="material-symbols-outlined">check_circle</span>
          Complete Transaction
        </button>
      </div>
    </div>

    <!-- Recent Transactions Section -->
    <div class="card" style="margin-top: 2rem;">
      <div class="card-header">
        <h2>Recent Transactions</h2>
        <button class="btn btn-ghost" id="refresh-transactions-btn">
          <span class="material-symbols-outlined">refresh</span>
          Refresh
        </button>
      </div>
      <div class="card-body">
        <div id="transactions-loading" class="hidden" style="text-align: center; padding: 2rem; color: var(--text-secondary);">
          <div class="spinner" style="margin: 0 auto 1rem;"></div>
          Loading transactions...
        </div>
        <div id="transactions-empty" class="hidden" style="text-align: center; padding: 3rem; color: var(--text-secondary);">
          <span class="material-symbols-outlined" style="font-size: 64px; opacity: 0.3;">receipt_long</span>
          <p>No transactions yet today</p>
        </div>
        <div id="transactions-table-container" class="table-container hidden">
          <table>
            <thead>
              <tr>
                <th>Time</th>
                <th>Transaction ID</th>
                <th>Items</th>
                <th>Payment</th>
                <th>Total</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="transactions-tbody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Success Modal -->
  <div id="success-modal" class="modal hidden">
    <div class="modal-overlay"></div>
    <div class="modal-content success-modal">
      <div class="success-icon">
        <span class="material-symbols-outlined">check_circle</span>
      </div>
      <h2>Transaction Complete!</h2>
      <div class="transaction-details">
        <div class="detail-row">
          <span>Transaction ID:</span>
          <span id="modal-txn-id" class="detail-value"></span>
        </div>
        <div class="detail-row">
          <span>Total Amount:</span>
          <span id="modal-amount" class="detail-value"></span>
        </div>
        <div class="detail-row">
          <span>Payment Method:</span>
          <span id="modal-method" class="detail-value"></span>
        </div>
      </div>
      <div class="modal-actions">
        <button class="btn btn-secondary" id="close-modal-btn">Close</button>
        <button class="btn btn-primary" id="print-receipt-btn">
          <span class="material-symbols-outlined">print</span>
          Print Receipt
        </button>
      </div>
    </div>
  </div>
</ModernLayout>

<script>
  import { db } from '../../services/firebase';
  import { collection, getDocs, query, where, orderBy, limit, limit as firestoreLimit, doc, getDoc, updateDoc, setDoc, Timestamp, runTransaction } from 'firebase/firestore';

  const skuInput = document.getElementById('sku-input') as HTMLInputElement;
  const searchDropdown = document.getElementById('search-dropdown')!;
  const productDisplay = document.getElementById('product-display')!;
  const productEmpty = document.getElementById('product-empty')!;
  const quantityInput = document.getElementById('quantity-input') as HTMLInputElement;
  const addToCartBtn = document.getElementById('add-to-cart-btn')!;
  const cartItemsContainer = document.getElementById('cart-items-container')!;
  const completeTransactionBtn = document.getElementById('complete-transaction-btn') as HTMLButtonElement;
  const successModal = document.getElementById('success-modal')!;

  let currentProduct: any = null;
  let cart: any[] = [];
  let selectedPaymentMethod = 'cash';
  let allProducts: any[] = [];
  let searchTimeout: any = null;

  const formatCurrency = (value: number) => `₱${value.toFixed(2)}`;

  const generateTransactionId = () => {
    const date = new Date();
    const year = date.getFullYear();
    const random = Math.floor(Math.random() * 1000000);
    return `TXN-${year}-${random.toString().padStart(6, '0')}`;
  };

  const loadAllProducts = async () => {
    try {
      const productsRef = collection(db!, 'products');
      const q = query(productsRef, where('isActive', '==', true));
      const snapshot = await getDocs(q);
      
      allProducts = snapshot.docs.map(doc => ({
        id: doc.id,
        ...doc.data()
      }));
      
      console.log(`Loaded ${allProducts.length} products for search`);
    } catch (error) {
      console.error('Error loading products:', error);
    }
  };

  const searchProducts = (searchText: string) => {
    if (!searchText || searchText.length < 2) {
      searchDropdown.classList.add('hidden');
      return;
    }

    const text = searchText.toLowerCase();
    const filtered = allProducts.filter(p => 
      p.sku?.toLowerCase().includes(text) || 
      p.description?.toLowerCase().includes(text)
    ).slice(0, 10);

    if (filtered.length === 0) {
      searchDropdown.classList.add('hidden');
      return;
    }

    searchDropdown.innerHTML = filtered.map(p => `
      <div class="search-result-item" data-sku="${p.sku}">
        <div class="result-main">
          <div class="result-name">${p.description}</div>
          <div class="result-sku">${p.sku}</div>
        </div>
      </div>
    `).join('');

    searchDropdown.classList.remove('hidden');

    // Add click handlers
    searchDropdown.querySelectorAll('.search-result-item').forEach(item => {
      item.addEventListener('click', () => {
        const sku = (item as HTMLElement).dataset.sku!;
        skuInput.value = sku;
        searchDropdown.classList.add('hidden');
        lookupProduct(sku);
      });
    });
  };

  const lookupProduct = async (sku?: string) => {
    const searchSku = sku || skuInput.value.trim().toUpperCase();
    if (!searchSku) return;

    searchDropdown.classList.add('hidden');

    searchDropdown.classList.add('hidden');

    try {
      let product: any = null;
      let productSKU = searchSku;

      // Try Method 1: Lookup by document ID (for products created with SKU as ID)
      const productRef = doc(db!, 'products', searchSku);
      const productSnap = await getDoc(productRef);

      if (productSnap.exists()) {
        product = { id: productSnap.id, ...productSnap.data() };
        productSKU = product.sku || searchSku;
      } else {
        // Method 2: Query by SKU field (for products with auto-generated IDs)
        const productsRef = collection(db!, 'products');
        const q = query(productsRef, where('sku', '==', searchSku), firestoreLimit(1));
        const querySnapshot = await getDocs(q);

        if (!querySnapshot.empty) {
          const docSnap = querySnapshot.docs[0];
          product = { id: docSnap.id, ...docSnap.data() };
          productSKU = product.sku;
        }
      }

      if (!product) {
        alert(`Product ${searchSku} not found`);
        return;
      }

      if (!product.isActive) {
        alert('Product is inactive');
        return;
      }

      // Get pricing - use the actual SKU from the product
      const pricingRef = doc(db!, 'pricing', `${productSKU}_standard`);
      const pricingSnap = await getDoc(pricingRef);
      const price = pricingSnap.exists() ? pricingSnap.data().retailPrice : 0;

      // Get inventory - use the actual SKU from the product
      const inventoryRef = doc(db!, 'inventory', `${productSKU}_warehouse`);
      const inventorySnap = await getDoc(inventoryRef);
      const stock = inventorySnap.exists() ? inventorySnap.data().quantityOnHand : 0;

      currentProduct = {
        ...product,
        sku: productSKU,
        price,
        stock
      };

      displayProduct(currentProduct);
    } catch (error) {
      console.error('Error:', error);
      alert('Error looking up product');
    }
  };

  const displayProduct = (product: any) => {
    document.getElementById('product-name')!.textContent = product.description;
    document.getElementById('product-sku')!.textContent = `SKU: ${product.sku}`;
    document.getElementById('product-price')!.textContent = formatCurrency(product.price);
    document.getElementById('product-stock')!.textContent = `Stock: ${product.stock} ${product.unitOfMeasure}`;

    productEmpty.classList.add('hidden');
    productDisplay.classList.remove('hidden');
    quantityInput.value = '1';
    quantityInput.max = product.stock.toString();
  };

  const addToCart = () => {
    if (!currentProduct) return;

    const quantity = parseInt(quantityInput.value);
    if (quantity <= 0 || quantity > currentProduct.stock) {
      alert('Invalid quantity');
      return;
    }

    const existingItem = cart.find(item => item.sku === currentProduct.sku);
    
    if (existingItem) {
      existingItem.quantity += quantity;
      existingItem.subtotal = existingItem.quantity * existingItem.price;
    } else {
      cart.push({
        sku: currentProduct.sku,
        description: currentProduct.description,
        price: currentProduct.price,
        quantity,
        subtotal: quantity * currentProduct.price,
        unitOfMeasure: currentProduct.unitOfMeasure
      });
    }

    renderCart();
    updateSummary();
    
    // Clear product display
    currentProduct = null;
    skuInput.value = '';
    productDisplay.classList.add('hidden');
    productEmpty.classList.remove('hidden');
    skuInput.focus();
  };

  const renderCart = () => {
    if (cart.length === 0) {
      cartItemsContainer.innerHTML = `
        <div class="cart-empty">
          <span class="material-symbols-outlined">shopping_cart</span>
          <p>No items in cart</p>
        </div>
      `;
      return;
    }

    cartItemsContainer.innerHTML = cart.map((item, index) => `
      <div class="cart-item">
        <div class="cart-item-info">
          <div class="cart-item-name">${item.description}</div>
          <div class="cart-item-sku">${item.sku}</div>
          <div class="cart-item-price">${formatCurrency(item.price)} × ${item.quantity}</div>
        </div>
        <div class="cart-item-actions">
          <div class="cart-item-subtotal">${formatCurrency(item.subtotal)}</div>
          <button class="btn-icon btn-danger remove-item-btn" data-index="${index}">
            <span class="material-symbols-outlined">delete</span>
          </button>
        </div>
      </div>
    `).join('');

    // Attach remove buttons
    document.querySelectorAll('.remove-item-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const index = parseInt((e.currentTarget as HTMLElement).dataset.index!);
        cart.splice(index, 1);
        renderCart();
        updateSummary();
      });
    });
  };

  const updateSummary = () => {
    const subtotal = cart.reduce((sum, item) => sum + item.subtotal, 0);
    const tax = 0; // 0% tax
    const total = subtotal + tax;

    document.getElementById('subtotal')!.textContent = formatCurrency(subtotal);
    document.getElementById('tax')!.textContent = formatCurrency(tax);
    document.getElementById('total')!.textContent = formatCurrency(total);

    // Update stats
    document.getElementById('cart-items')!.textContent = cart.length.toString();
    document.getElementById('cart-total')!.textContent = formatCurrency(total);

    // Enable/disable complete button
    completeTransactionBtn.disabled = cart.length === 0;
  };

  const completeTransaction = async () => {
    if (cart.length === 0) return;

    const confirmed = confirm(`Complete transaction with ${selectedPaymentMethod}?\n\nThis will:\n- Update inventory\n- Create transaction record\n- Add to audit log\n\nNote: This is a simulated payment (no real money transferred)`);
    if (!confirmed) return;

    (completeTransactionBtn as HTMLButtonElement).disabled = true;
    completeTransactionBtn.innerHTML = '<span class="material-symbols-outlined spinning">refresh</span> Processing...';

    try {
      const transactionId = generateTransactionId();
      const subtotal = cart.reduce((sum, item) => sum + item.subtotal, 0);
      const tax = 0;
      const total = subtotal + tax;

      // Create transaction document
      const transactionRef = doc(db!, 'pos_transactions', transactionId);
      console.log('Creating transaction:', transactionId);
      await setDoc(transactionRef, {
        transactionId,
        timestamp: Timestamp.now(),
        items: cart.map(item => ({
          sku: item.sku,
          description: item.description,
          quantity: item.quantity,
          unitPrice: item.price,
          subtotal: item.subtotal
        })),
        subtotal,
        tax,
        total,
        paymentMethod: selectedPaymentMethod,
        status: 'completed',
        cashierId: 'demo-user',
        locationId: 'warehouse'
      });
      console.log('Transaction created successfully');

      // Update inventory for each item
      for (const item of cart) {
        const inventoryRef = doc(db!, 'inventory', `${item.sku}_warehouse`);
        const inventorySnap = await getDoc(inventoryRef);
        
        if (inventorySnap.exists()) {
          const currentQty = inventorySnap.data().quantityOnHand;
          await updateDoc(inventoryRef, {
            quantityOnHand: currentQty - item.quantity,
            lastUpdated: Timestamp.now()
          });
        }

        // Create inventory transaction log
        const invTxnRef = doc(collection(db!, 'inventory_transactions'));
        await setDoc(invTxnRef, {
          transactionId: invTxnRef.id,
          sku: item.sku,
          locationId: 'warehouse',
          transactionType: 'sale',
          quantity: -item.quantity,
          referenceId: transactionId,
          performedBy: 'demo-user',
          timestamp: Timestamp.now(),
          notes: `POS Sale - ${transactionId}`
        });
      }

      // Show success modal
      document.getElementById('modal-txn-id')!.textContent = transactionId;
      document.getElementById('modal-amount')!.textContent = formatCurrency(total);
      document.getElementById('modal-method')!.textContent = selectedPaymentMethod.toUpperCase();
      successModal.classList.remove('hidden');

      // Clear cart
      cart = [];
      renderCart();
      updateSummary();
      
      // Reload stats and transactions
      await loadTodayStats();
      await loadRecentTransactions();

    } catch (error) {
      console.error('Transaction error:', error);
      alert(`Error: ${error instanceof Error ? error.message : 'Failed to complete transaction'}`);
    } finally {
      (completeTransactionBtn as HTMLButtonElement).disabled = false;
      completeTransactionBtn.innerHTML = '<span class="material-symbols-outlined">check_circle</span> Complete Transaction';
    }
  };

  const loadTodayStats = async () => {
    try {
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      
      const transactionsRef = collection(db!, 'pos_transactions');
      // Simplified query - just filter by timestamp
      const q = query(
        transactionsRef,
        where('timestamp', '>=', Timestamp.fromDate(today))
      );
      const snapshot = await getDocs(q);

      let totalSales = 0;
      let transactionCount = 0;

      // Filter completed status in memory instead of query
      snapshot.forEach(doc => {
        const data = doc.data();
        if (data.status === 'completed') {
          totalSales += data.total || 0;
          transactionCount++;
        }
      });

      document.getElementById('today-sales')!.textContent = formatCurrency(totalSales);
      document.getElementById('today-transactions')!.textContent = transactionCount.toString();
    } catch (error) {
      console.error('Error loading stats:', error);
    }
  };

  const loadRecentTransactions = async () => {
    const transactionsTbody = document.getElementById('transactions-tbody')!;
    const transactionsTableContainer = document.getElementById('transactions-table-container')!;
    const transactionsLoading = document.getElementById('transactions-loading')!;
    const transactionsEmpty = document.getElementById('transactions-empty')!;

    try {
      transactionsLoading.classList.remove('hidden');
      transactionsTbody.innerHTML = '';
      transactionsTableContainer.classList.add('hidden');
      transactionsEmpty.classList.add('hidden');

      const today = new Date();
      today.setHours(0, 0, 0, 0);
      
      const transactionsRef = collection(db!, 'pos_transactions');
      // Simplified query - just filter by timestamp, order by timestamp desc
      const q = query(
        transactionsRef,
        where('timestamp', '>=', Timestamp.fromDate(today)),
        orderBy('timestamp', 'desc'),
        firestoreLimit(20)  // Get 20 to filter down to 10 completed
      );
      const snapshot = await getDocs(q);

      transactionsLoading.classList.add('hidden');

      // Filter for completed transactions in memory
      const completedTransactions = snapshot.docs
        .map(doc => doc.data())
        .filter(txn => txn.status === 'completed')
        .slice(0, 10);  // Take first 10

      if (completedTransactions.length === 0) {
        transactionsEmpty.classList.remove('hidden');
        return;
      }

      transactionsTableContainer.classList.remove('hidden');

      completedTransactions.forEach(txn => {
        const txnDate = txn.timestamp?.toDate() || new Date();
        const timeStr = txnDate.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });

        const row = document.createElement('tr');
        row.innerHTML = `
          <td class="time-cell">${timeStr}</td>
          <td>
            <div class="txn-id-cell">
              <span class="material-symbols-outlined" style="font-size: 18px; color: var(--primary);">receipt</span>
              <span>${txn.transactionId}</span>
            </div>
          </td>
          <td class="text-center">${txn.items?.length || 0}</td>
          <td>
            <span class="badge badge-${getPaymentBadgeClass(txn.paymentMethod)}">${txn.paymentMethod?.toUpperCase() || 'CASH'}</span>
          </td>
          <td class="total-cell">${formatCurrency(txn.total || 0)}</td>
          <td>
            <button class="btn-icon" title="View details">
              <span class="material-symbols-outlined">visibility</span>
            </button>
          </td>
        `;
        transactionsTbody.appendChild(row);
      });

    } catch (error) {
      console.error('Error loading transactions:', error);
      transactionsLoading.classList.add('hidden');
      transactionsEmpty.classList.remove('hidden');
    }
  };

  const getPaymentBadgeClass = (method: string) => {
    const methodLower = method?.toLowerCase() || 'cash';
    if (methodLower === 'cash') return 'success';
    if (methodLower === 'card') return 'info';
    if (methodLower === 'gcash') return 'warning';
    return 'secondary';
  };

  // Event Listeners
  skuInput.addEventListener('input', (e) => {
    const searchText = (e.target as HTMLInputElement).value;
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => searchProducts(searchText), 300);
  });
  
  skuInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      searchDropdown.classList.add('hidden');
      lookupProduct();
    }
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    if (!skuInput.contains(e.target as Node) && !searchDropdown.contains(e.target as Node)) {
      searchDropdown.classList.add('hidden');
    }
  });

  addToCartBtn.addEventListener('click', addToCart);

  document.getElementById('clear-cart-btn')!.addEventListener('click', () => {
    if (cart.length === 0) return;
    if (confirm('Clear all items from cart?')) {
      cart = [];
      renderCart();
      updateSummary();
    }
  });

  document.getElementById('clear-all-btn')!.addEventListener('click', () => {
    if (cart.length === 0) return;
    if (confirm('Start new sale? This will clear the current cart.')) {
      cart = [];
      currentProduct = null;
      skuInput.value = '';
      productDisplay.classList.add('hidden');
      productEmpty.classList.remove('hidden');
      renderCart();
      updateSummary();
      skuInput.focus();
    }
  });

  document.querySelectorAll('.payment-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      document.querySelectorAll('.payment-btn').forEach(b => b.classList.remove('active'));
      (e.currentTarget as HTMLElement).classList.add('active');
      selectedPaymentMethod = (e.currentTarget as HTMLElement).dataset.method!;
    });
  });

  completeTransactionBtn.addEventListener('click', completeTransaction);

  document.getElementById('close-modal-btn')!.addEventListener('click', () => {
    successModal.classList.add('hidden');
  });

  document.getElementById('print-receipt-btn')!.addEventListener('click', () => {
    alert('Print functionality would be implemented here');
    successModal.classList.add('hidden');
  });

  document.getElementById('refresh-transactions-btn')!.addEventListener('click', () => {
    loadTodayStats();
    loadRecentTransactions();
  });

  // Initialize
  loadAllProducts();
