---
/**
 * Receiving Record Detail Page - Client-Side
 * 
 * Displays detailed information about a specific receiving record.
 */

import ModernLayout from '../../layouts/ModernLayout.astro';

Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');
---

<ModernLayout title="Receiving Details">
  <div class="receiving-detail-page">
    <!-- Page Header -->
    <div class="page-header">
      <div>
        <h1>
          <span class="material-symbols-outlined" style="vertical-align: middle; margin-right: 0.5rem;">receipt_long</span>
          Receiving Details
        </h1>
        <p class="subtitle">View receiving record information</p>
      </div>
      <a href="/receiving" class="btn btn-secondary">
        <span class="material-symbols-outlined">arrow_back</span>
        Back to List
      </a>
    </div>

    <!-- Loading State -->
    <div id="loading-state" class="loading-container">
      <div class="spinner"></div>
      <p style="margin-top: 1rem; color: var(--text-secondary);">Loading receiving record...</p>
    </div>

    <!-- Error Display -->
    <div id="error-display" class="hidden">
      <div class="alert alert-error">
        <span class="material-symbols-outlined">error</span>
        <div>
          <strong>Error:</strong> <span id="error-message"></span>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div id="content" class="hidden">
      <!-- Variance Alert -->
      <div id="variance-alert" class="alert alert-warning hidden">
        <span class="material-symbols-outlined">warning</span>
        <div>
          <strong>Variance Detected:</strong>
          <p>This receiving record has quantity discrepancies exceeding 5%.</p>
        </div>
      </div>

      <!-- Basic Information Card -->
      <div class="card">
        <div class="card-header">
          <h2>Basic Information</h2>
          <span id="status-badge"></span>
        </div>
        <div class="card-body">
          <div class="info-grid">
            <div class="info-item">
              <span class="info-label">Receiving ID</span>
              <span class="info-value font-mono" id="receiving-id"></span>
            </div>
            <div class="info-item">
              <span class="info-label">Supplier</span>
              <span class="info-value" id="supplier-name"></span>
            </div>
            <div class="info-item">
              <span class="info-label">Receiving Date</span>
              <span class="info-value" id="receiving-date"></span>
            </div>
            <div class="info-item">
              <span class="info-label">Document Type</span>
              <span class="info-value" id="document-type"></span>
            </div>
            <div class="info-item">
              <span class="info-label">Total Items</span>
              <span class="info-value" id="total-items"></span>
            </div>
            <div class="info-item">
              <span class="info-label">Total Quantity</span>
              <span class="info-value" id="total-quantity"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Line Items Card -->
      <div class="card">
        <div class="card-header">
          <h2>Line Items</h2>
        </div>
        <div class="card-body">
          <div class="table-container">
            <table>
              <thead>
                <tr>
                  <th>SKU</th>
                  <th>Product</th>
                  <th>Location</th>
                  <th>Received</th>
                  <th>Expected</th>
                  <th>Variance</th>
                </tr>
              </thead>
              <tbody id="line-items-tbody"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</ModernLayout>

<script>
  import { db } from '../../services/firebase';
  import { doc, getDoc, collection, getDocs } from 'firebase/firestore';

  const loadingState = document.getElementById('loading-state')!;
  const errorDisplay = document.getElementById('error-display')!;
  const errorMessage = document.getElementById('error-message')!;
  const content = document.getElementById('content')!;
  const varianceAlert = document.getElementById('variance-alert')!;

  // Get record ID from URL
  const urlParams = new URLSearchParams(window.location.search);
  const recordId = urlParams.get('id');

  if (!recordId) {
    errorDisplay.classList.remove('hidden');
    errorMessage.textContent = 'No receiving record ID provided';
    loadingState.classList.add('hidden');
  } else {
    loadRecord();
  }

  const formatDate = (date: Date) => {
    return new Intl.DateTimeFormat('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    }).format(date);
  };

  async function loadRecord() {
    try {
      loadingState.classList.remove('hidden');
      errorDisplay.classList.add('hidden');

      // Load record
      const recordRef = doc(db!, 'receiving_records', recordId!);
      const recordSnap = await getDoc(recordRef);

      if (!recordSnap.exists()) {
        throw new Error('Receiving record not found');
      }

      const record = { id: recordSnap.id, ...recordSnap.data() } as any;

      // Load supplier name
      const suppliersRef = collection(db!, 'suppliers');
      const suppliersSnap = await getDocs(suppliersRef);
      const suppliersMap = new Map();
      suppliersSnap.forEach(doc => {
        suppliersMap.set(doc.id, doc.data().name);
      });

      // Load products for SKU display
      const productsRef = collection(db!, 'products');
      const productsSnap = await getDocs(productsRef);
      const productsMap = new Map();
      productsSnap.forEach(doc => {
        productsMap.set(doc.data().sku, doc.data());
      });

      // Display basic info
      document.getElementById('receiving-id')!.textContent = record.receivingId;
      document.getElementById('supplier-name')!.textContent = suppliersMap.get(record.supplierId) || 'Unknown';
      document.getElementById('receiving-date')!.textContent = formatDate(record.receivingDate.toDate());
      
      const docType = record.documentType === 'invoice' ? 'Invoice' : 'Delivery Receipt';
      document.getElementById('document-type')!.textContent = docType;

      const itemCount = record.lineItems?.length || 0;
      const totalQty = record.lineItems?.reduce((sum: number, item: any) => sum + (item.quantity || 0), 0) || 0;
      
      document.getElementById('total-items')!.textContent = itemCount.toString();
      document.getElementById('total-quantity')!.textContent = totalQty.toString();

      // Status badge
      const statusBadge = document.getElementById('status-badge')!;
      if (record.status === 'completed') {
        if (record.hasVariance) {
          statusBadge.innerHTML = '<span class="badge badge-warning">Completed (Variance)</span>';
          varianceAlert.classList.remove('hidden');
        } else {
          statusBadge.innerHTML = '<span class="badge badge-success">Completed</span>';
        }
      } else {
        statusBadge.innerHTML = '<span class="badge badge-secondary">Pending</span>';
      }

      // Display line items
      const tbody = document.getElementById('line-items-tbody')!;
      tbody.innerHTML = '';

      if (record.lineItems && record.lineItems.length > 0) {
        record.lineItems.forEach((item: any) => {
          const product = productsMap.get(item.sku);
          const row = document.createElement('tr');

          let varianceCell = '<td class="text-center">-</td>';
          if (item.expectedQuantity) {
            const variance = Math.abs(item.quantity - item.expectedQuantity);
            const variancePercent = (variance / item.expectedQuantity) * 100;
            
            if (variancePercent > 5) {
              varianceCell = `<td class="text-center"><span class="badge badge-warning">${variancePercent.toFixed(1)}%</span></td>`;
            } else {
              varianceCell = `<td class="text-center"><span class="badge badge-success">OK</span></td>`;
            }
          }

          row.innerHTML = `
            <td class="font-mono">${item.sku}</td>
            <td>${product?.description || 'Unknown Product'}</td>
            <td>${item.locationId}</td>
            <td class="text-center font-semibold">${item.quantity}</td>
            <td class="text-center">${item.expectedQuantity || '-'}</td>
            ${varianceCell}
          `;
          tbody.appendChild(row);
        });
      } else {
        tbody.innerHTML = '<tr><td colspan="6" class="text-center" style="padding: 2rem;">No line items</td></tr>';
      }

      loadingState.classList.add('hidden');
      content.classList.remove('hidden');
    } catch (err) {
      loadingState.classList.add('hidden');
      errorDisplay.classList.remove('hidden');
      errorMessage.textContent = err instanceof Error ? err.message : 'Failed to load';
      console.error('Error loading record:', err);
    }
  }
</script>

<style>
  .receiving-detail-page {
    padding: 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
    gap: 2rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
    color: var(--text-primary);
    display: flex;
    align-items: center;
  }

  .subtitle {
    color: var(--text-secondary);
    margin: 0;
  }

  .loading-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
  }

  .spinner {
    width: 48px;
    height: 48px;
    border: 4px solid var(--border-color);
    border-top-color: var(--primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .hidden {
    display: none !important;
  }

  .alert {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    border: 1px solid;
  }

  .alert-error {
    background: #fef2f2;
    color: #991b1b;
    border-color: #fca5a5;
  }

  .alert-warning {
    background: #fffbeb;
    color: #92400e;
    border-color: #fcd34d;
  }

  .alert .material-symbols-outlined {
    font-size: 24px;
  }

  .card {
    background: white;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    background: var(--surface-secondary);
    border-bottom: 1px solid var(--border-color);
  }

  .card-header h2 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
  }

  .card-body {
    padding: 1.5rem;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .info-label {
    font-size: 0.875rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .info-value {
    font-size: 1.125rem;
    color: var(--text-primary);
  }

  .font-mono {
    font-family: 'Courier New', monospace;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .badge-success {
    background: #d1fae5;
    color: #059669;
  }

  .badge-warning {
    background: #fef3c7;
    color: #d97706;
  }

  .badge-secondary {
    background: #f3f4f6;
    color: #6b7280;
  }

  .table-container {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  thead th {
    background: var(--surface-secondary);
    padding: 1rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-color);
  }

  tbody td {
    padding: 1rem;
    border-bottom: 1px solid var(--border-color);
  }

  tbody tr:hover {
    background: var(--surface-secondary);
  }

  .text-center {
    text-align: center;
  }

  .font-semibold {
    font-weight: 600;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    font-weight: 500;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-secondary {
    background: white;
    color: var(--text-primary);
    border: 1px solid var(--border-color);
  }

  .btn-secondary:hover {
    background: var(--surface-secondary);
  }

  @media (max-width: 768px) {
    .receiving-detail-page {
      padding: 1rem;
    }

    .page-header {
      flex-direction: column;
      gap: 1rem;
    }

    .info-grid {
      grid-template-columns: 1fr;
    }

    table {
      font-size: 0.875rem;
    }

    thead th,
    tbody td {
      padding: 0.75rem 0.5rem;
    }
  }
</style>
