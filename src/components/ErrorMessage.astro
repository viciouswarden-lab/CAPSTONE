---
/**
 * ErrorMessage Component
 * 
 * Displays validation errors and error messages with specific guidance.
 * Validates Requirements 20.2, 20.3
 * 
 * Props:
 * - message: The error message text to display
 * - field: Optional field name for inline validation errors
 * - type: 'error' | 'warning' | 'info' - severity level (default: 'error')
 * - dismissable: Whether the error can be dismissed by the user (default: false)
 */

interface Props {
  message: string;
  field?: string;
  type?: 'error' | 'warning' | 'info';
  dismissable?: boolean;
}

const { message, field, type = 'error', dismissable = false } = Astro.props;

// Determine styling based on error type
const typeStyles = {
  error: {
    bg: 'bg-red-50',
    border: 'border-red-300',
    text: 'text-red-800',
    icon: '❌'
  },
  warning: {
    bg: 'bg-yellow-50',
    border: 'border-yellow-300',
    text: 'text-yellow-800',
    icon: '⚠️'
  },
  info: {
    bg: 'bg-blue-50',
    border: 'border-blue-300',
    text: 'text-blue-800',
    icon: 'ℹ️'
  }
};

const styles = typeStyles[type];
---

<div 
  class={`error-message ${styles.bg} ${styles.border} ${styles.text} border rounded-md p-3 mb-3 flex items-start gap-2`}
  role="alert"
  data-field={field}
>
  <span class="error-icon text-lg" aria-hidden="true">{styles.icon}</span>
  <div class="flex-1">
    {field && <span class="font-semibold">{field}: </span>}
    <span class="error-text">{message}</span>
  </div>
  {dismissable && (
    <button
      class="dismiss-btn ml-2 text-gray-500 hover:text-gray-700 focus:outline-none"
      aria-label="Dismiss error"
      onclick="this.parentElement.remove()"
    >
      ✕
    </button>
  )}
</div>

<style>
  .error-message {
    animation: slideIn 0.3s ease-out;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .dismiss-btn {
    transition: opacity 0.2s;
  }

  .dismiss-btn:hover {
    opacity: 0.7;
  }
</style>
